---
import zielgruppen from '../data/zielgruppen.json';
import company from '../data/company.json';

const enableBlog = import.meta.env.PUBLIC_ENABLE_BLOG === 'true';
const enableReferenzen = import.meta.env.PUBLIC_ENABLE_REFERENZEN === 'true';
const enableZielgruppen = import.meta.env.PUBLIC_ENABLE_ZIELGRUPPEN === 'true';
const enableLeistungen = import.meta.env.PUBLIC_ENABLE_LEISTUNGEN === 'true';
const enableTransparenz = import.meta.env.PUBLIC_ENABLE_TRANSPARENZ === 'true';
const enableGlossar = import.meta.env.PUBLIC_ENABLE_GLOSSAR === 'true';

const currentYear = new Date().getFullYear();

const links = {
  leistungen: [
    enableLeistungen && { label: 'Strom & Gas', href: '/leistungen' },
    ...(enableZielgruppen ? zielgruppen.map((z) => ({ label: z.navLabel, href: `/zielgruppen/${z.slug}` })) : []),
  ].filter(Boolean),
  unternehmen: [
    enableTransparenz && { label: 'Über uns', href: '/transparenz' },
    enableReferenzen && { label: 'Referenzen', href: '/referenzen' },
    enableBlog && { label: 'Blog', href: '/blog' },
    enableGlossar && { label: 'Glossar', href: '/glossar' },
    { label: 'Kontakt', href: '/kontakt' },
  ].filter(Boolean),
  rechtliches: [
    { label: 'Impressum', href: '/impressum' },
    { label: 'Datenschutz', href: '/datenschutz' },
    { label: 'Cookie-Richtlinie', href: '/cookie-richtlinie' },
  ],
};

---

<!-- Pre-footer CTA -->
<section class="bg-brand-400 border-y-4 border-dark-900">
  <div class="container-wide py-12 sm:py-16 text-center">
    <p class="text-[0.72rem] font-extrabold uppercase tracking-[0.22em] text-dark-900/70 mb-3">Kostenloser Tarifcheck</p>
    <h2 class="text-3xl sm:text-5xl font-heading font-extrabold text-dark-950 mb-4 leading-none">
      Bereit, Energiekosten zu senken?
    </h2>
    <p class="text-dark-900/72 mb-8 max-w-xl mx-auto font-medium">
      Unverbindliche Anfrage in 2&nbsp;Minuten – wir finden den besten Tarif für Sie.
    </p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a href="/anfrage"
         class="inline-flex items-center justify-center gap-2 px-8 py-4 text-sm font-extrabold uppercase tracking-[0.14em] text-white bg-dark-900 border border-dark-900 shadow-[5px_5px_0_rgba(255,255,255,0.42)] hover:translate-x-[2px] hover:translate-y-[2px] hover:shadow-[3px_3px_0_rgba(255,255,255,0.42)] active:translate-x-[5px] active:translate-y-[5px] active:shadow-none transition-all duration-150">
        Kostenlos anfragen
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
      <a href="/termin"
         class="inline-flex items-center justify-center gap-2 px-8 py-4 text-sm font-extrabold uppercase tracking-[0.14em] text-dark-950 border border-dark-900 hover:bg-dark-900 hover:text-white transition-all duration-200">
        Termin vereinbaren
      </a>
    </div>
  </div>
</section>

<footer class="relative overflow-hidden bg-dark-900 text-white">
  <div class="absolute inset-0 opacity-[0.08] pointer-events-none" style="background-image: repeating-linear-gradient(135deg, transparent 0 42px, #e7b345 42px 44px);"></div>
  <div class="container-wide py-12 lg:py-16">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8 lg:gap-12">
      <!-- Brand Column -->
      <div class="relative col-span-2 md:col-span-1">
        <a href="/" class="inline-flex mb-5" aria-label="Energierichter Startseite">
          <img
            src="/assets/brand/energierichter-logo-horizontal-dark.png"
            alt="Energierichter"
            width="1684"
            height="515"
            class="h-9 w-auto"
          />
        </a>
        <p class="text-sm text-white/62 leading-relaxed mb-5">
          Unabhängiger Energierichter – wir finden den besten Tarif für Strom &amp; Gas.
        </p>
        <div class="flex items-center gap-2 text-sm text-brand-400 font-semibold">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M22 16.92v3a2 2 0 01-2.18 2A19.86 19.86 0 013.09 5.18 2 2 0 015.11 3h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 11.91a16 16 0 006 6l2.27-2.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
          {company.phone}
        </div>
      </div>

      <!-- Leistungen -->
      <div class="relative">
        <h3 class="text-xs font-extrabold text-brand-400 uppercase tracking-[0.18em] mb-4">Leistungen</h3>
        <ul class="space-y-2.5">
          {links.leistungen.map((l) => (
            <li><a href={l.href} class="text-sm text-white/62 hover:text-brand-400 transition-colors">{l.label}</a></li>
          ))}
        </ul>
      </div>

      <!-- Unternehmen -->
      <div class="relative">
        <h3 class="text-xs font-extrabold text-brand-400 uppercase tracking-[0.18em] mb-4">Unternehmen</h3>
        <ul class="space-y-2.5">
          {links.unternehmen.map((l) => (
            <li><a href={l.href} class="text-sm text-white/62 hover:text-brand-400 transition-colors">{l.label}</a></li>
          ))}
        </ul>
      </div>

      <!-- Rechtliches -->
      <div class="relative">
        <h3 class="text-xs font-extrabold text-brand-400 uppercase tracking-[0.18em] mb-4">Rechtliches</h3>
        <ul class="space-y-2.5">
          {links.rechtliches.map((l) => (
            <li><a href={l.href} class="text-sm text-white/62 hover:text-brand-400 transition-colors">{l.label}</a></li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="relative mt-12 pt-8 border-t border-white/10 flex flex-col sm:flex-row items-center justify-between gap-4 text-xs text-white/42">
      <p>&copy; {currentYear} Energierichter. Alle Rechte vorbehalten.</p>
      <p>{company.tagline}</p>
    </div>
  </div>
</footer>
