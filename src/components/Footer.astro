---
import zielgruppen from '../data/zielgruppen.json';
import company from '../data/company.json';

const enableBlog = import.meta.env.PUBLIC_ENABLE_BLOG === 'true';
const enableReferenzen = import.meta.env.PUBLIC_ENABLE_REFERENZEN === 'true';
const enableZielgruppen = import.meta.env.PUBLIC_ENABLE_ZIELGRUPPEN === 'true';
const enableLeistungen = import.meta.env.PUBLIC_ENABLE_LEISTUNGEN === 'true';
const enableTransparenz = import.meta.env.PUBLIC_ENABLE_TRANSPARENZ === 'true';
const enableGlossar = import.meta.env.PUBLIC_ENABLE_GLOSSAR === 'true';

const currentYear = new Date().getFullYear();

const links = {
  leistungen: [
    enableLeistungen && { label: 'Strom & Gas', href: '/leistungen' },
    ...(enableZielgruppen ? zielgruppen.map((z) => ({ label: z.navLabel, href: `/zielgruppen/${z.slug}` })) : []),
  ].filter(Boolean),
  unternehmen: [
    enableTransparenz && { label: 'Über uns', href: '/transparenz' },
    enableReferenzen && { label: 'Referenzen', href: '/referenzen' },
    enableBlog && { label: 'Blog', href: '/blog' },
    enableGlossar && { label: 'Glossar', href: '/glossar' },
    { label: 'Kontakt', href: '/kontakt' },
  ].filter(Boolean),
  rechtliches: [
    { label: 'Impressum', href: '/impressum' },
    { label: 'Datenschutz', href: '/datenschutz' },
    { label: 'Cookie-Richtlinie', href: '/cookie-richtlinie' },
  ],
};

---

<!-- Pre-footer CTA -->
<section class="bg-dark-900 border-y border-brand-400/25">
  <div class="container-wide py-20 sm:py-24 text-center">
    <p class="mb-5 text-[0.68rem] font-semibold uppercase tracking-[0.22em] text-brand-300">Kostenloser Tarifcheck</p>
    <h2 class="text-4xl sm:text-5xl lg:text-6xl font-heading font-semibold text-white mb-5 leading-[1.02]">
      Bereit, Energiekosten zu senken?
    </h2>
    <p class="text-white/60 mb-10 max-w-xl mx-auto text-sm sm:text-base leading-7">
      Unverbindliche Anfrage in 2&nbsp;Minuten – wir finden den besten Tarif für Sie.
    </p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a href="/anfrage"
         class="inline-flex items-center justify-center gap-2 border border-brand-400 bg-brand-400 px-8 py-4 text-[0.72rem] font-bold uppercase tracking-[0.16em] text-dark-950 hover:bg-transparent hover:text-brand-300 transition-all duration-200">
        Kostenlos anfragen
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
      <a href="/termin"
         class="inline-flex items-center justify-center gap-2 border border-white/18 px-8 py-4 text-[0.72rem] font-bold uppercase tracking-[0.16em] text-white/78 hover:border-brand-400/70 hover:text-brand-300 transition-all duration-200">
        Termin vereinbaren
      </a>
    </div>
  </div>
</section>

<footer class="relative overflow-hidden bg-[#080b0f] text-gray-300">
  <div class="absolute inset-0 opacity-[0.045] pointer-events-none" style="background-image: repeating-linear-gradient(135deg, transparent 0 56px, #f5c542 56px 57px);"></div>
  <div class="container-wide py-12 lg:py-16">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8 lg:gap-12">
      <!-- Brand Column -->
      <div class="relative col-span-2 md:col-span-1">
        <a href="/" class="inline-flex mb-5" aria-label="Energierichter Startseite">
          <img
            src="/assets/brand/er-logo.svg"
            alt="Energierichter"
            width="1400"
            height="650"
            class="h-12 w-auto opacity-95"
          />
        </a>
        <p class="font-heading text-2xl font-semibold text-white mb-3">Energierichter</p>
        <p class="text-sm text-white/52 leading-7 mb-5">
          Unabhängiger Energierichter – wir finden den besten Tarif für Strom &amp; Gas.
        </p>
        <div class="flex items-center gap-2 text-sm text-brand-300/85">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M22 16.92v3a2 2 0 01-2.18 2A19.86 19.86 0 013.09 5.18 2 2 0 015.11 3h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 11.91a16 16 0 006 6l2.27-2.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
          {company.phone}
        </div>
      </div>

      <!-- Leistungen -->
      <div class="relative">
        <h3 class="text-[0.68rem] font-semibold text-brand-300 uppercase tracking-[0.22em] mb-5">Leistungen</h3>
        <ul class="space-y-2.5">
          {links.leistungen.map((l) => (
            <li><a href={l.href} class="text-sm text-white/50 hover:text-brand-300 transition-colors">{l.label}</a></li>
          ))}
        </ul>
      </div>

      <!-- Unternehmen -->
      <div class="relative">
        <h3 class="text-[0.68rem] font-semibold text-brand-300 uppercase tracking-[0.22em] mb-5">Unternehmen</h3>
        <ul class="space-y-2.5">
          {links.unternehmen.map((l) => (
            <li><a href={l.href} class="text-sm text-white/50 hover:text-brand-300 transition-colors">{l.label}</a></li>
          ))}
        </ul>
      </div>

      <!-- Rechtliches -->
      <div class="relative">
        <h3 class="text-[0.68rem] font-semibold text-brand-300 uppercase tracking-[0.22em] mb-5">Rechtliches</h3>
        <ul class="space-y-2.5">
          {links.rechtliches.map((l) => (
            <li><a href={l.href} class="text-sm text-white/50 hover:text-brand-300 transition-colors">{l.label}</a></li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="relative mt-12 pt-8 border-t border-white/10 flex flex-col sm:flex-row items-center justify-between gap-4 text-xs text-white/34">
      <p>&copy; {currentYear} Energierichter. Alle Rechte vorbehalten.</p>
      <p>{company.tagline}</p>
    </div>
  </div>
</footer>
