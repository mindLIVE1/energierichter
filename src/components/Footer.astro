---
import PreFooterCta from './sections/PreFooterCta.astro';
import zielgruppen from '../data/zielgruppen.json';
import company from '../data/company.json';

interface Props {
  isTerminPage?: boolean;
}

const { isTerminPage = false } = Astro.props;

const disableBlog = import.meta.env.PUBLIC_DISABLE_BLOG === 'true';
const disableReferenzen = import.meta.env.PUBLIC_DISABLE_REFERENZEN === 'true';
const disableZielgruppen = import.meta.env.PUBLIC_DISABLE_ZIELGRUPPEN === 'true';
const disableLeistungen = import.meta.env.PUBLIC_DISABLE_LEISTUNGEN === 'true';
const disableTransparenz = import.meta.env.PUBLIC_DISABLE_TRANSPARENZ === 'true';
const disableGlossar = import.meta.env.PUBLIC_DISABLE_GLOSSAR === 'true';

const currentYear = new Date().getFullYear();

const links = {
  leistungen: [
    !disableLeistungen && { label: 'Strom & Gas', href: '/leistungen' },
    ...(!disableZielgruppen ? zielgruppen.map((z) => ({ label: z.navLabel, href: `/zielgruppen/${z.slug}` })) : []),
  ].filter(Boolean),
  unternehmen: [
    !disableTransparenz && { label: 'Über uns', href: '/transparenz' },
    !disableReferenzen && { label: 'Referenzen', href: '/referenzen' },
    !disableBlog && { label: 'Blog', href: '/blog' },
    !disableGlossar && { label: 'Glossar', href: '/glossar' },
    { label: 'Kontakt', href: '/kontakt' },
  ].filter(Boolean),
  rechtliches: [
    { label: 'Impressum', href: '/impressum' },
    { label: 'Datenschutz', href: '/datenschutz' },
    { label: 'Cookie-Richtlinie', href: '/cookie-richtlinie' },
  ],
};
---

<!-- Pre-footer CTA -->
<PreFooterCta isTerminPage={isTerminPage} />

<footer class="relative overflow-hidden bg-[#080b0f] text-gray-300" data-section="Footer">
  <div class="absolute inset-0 opacity-[0.045] pointer-events-none" style="background-image: repeating-linear-gradient(135deg, transparent 0 56px, #f5c542 56px 57px);"></div>
  <div class="container-wide py-12 lg:py-16">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8 lg:gap-12">
      <!-- Brand Column -->
      <div class="relative col-span-2 md:col-span-1">
        <a href="/" class="inline-flex mb-5" aria-label="Energierichter Startseite">
          <img
            src="/assets/brand/er-logo.svg"
            alt="Energierichter"
            width="1400"
            height="650"
            class="h-12 w-auto opacity-95"
          />
        </a>
        <p class="font-heading text-2xl font-semibold text-white mb-3">Energierichter</p>
        <p class="text-sm text-white/52 leading-7 mb-5">
          Unabhängiger Energiemakler – wir finden den besten Tarif für Strom &amp; Gas.
        </p>
        <div class="space-y-2">
          <div class="flex items-center gap-2 text-sm text-brand-300/85">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M22 16.92v3a2 2 0 01-2.18 2A19.86 19.86 0 013.09 5.18 2 2 0 015.11 3h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 11.91a16 16 0 006 6l2.27-2.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
            {company.phone}
          </div>
          <div class="flex items-center gap-2 text-sm text-brand-300/85">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="1.5" /><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7" /></svg>
            <a href={`mailto:${company.email}`} class="hover:text-brand-400 transition-colors duration-200">{company.email}</a>
          </div>
        </div>
      </div>

      <!-- Leistungen -->
      <div class="relative">
        <h3 class="text-[0.68rem] font-semibold text-brand-300 uppercase tracking-[0.22em] mb-5">Leistungen</h3>
        <ul class="space-y-2.5">
          {links.leistungen.map((l) => (
            <li><a href={l.href} class="text-sm text-white/50 hover:text-brand-300 transition-colors">{l.label}</a></li>
          ))}
        </ul>
      </div>

      <!-- Unternehmen -->
      <div class="relative">
        <h3 class="text-[0.68rem] font-semibold text-brand-300 uppercase tracking-[0.22em] mb-5">Unternehmen</h3>
        <ul class="space-y-2.5">
          {links.unternehmen.map((l) => (
            <li><a href={l.href} class="text-sm text-white/50 hover:text-brand-300 transition-colors">{l.label}</a></li>
          ))}
        </ul>
      </div>

      <!-- Rechtliches -->
      <div class="relative">
        <h3 class="text-[0.68rem] font-semibold text-brand-300 uppercase tracking-[0.22em] mb-5">Rechtliches</h3>
        <ul class="space-y-2.5">
          {links.rechtliches.map((l) => (
            <li><a href={l.href} class="text-sm text-white/50 hover:text-brand-300 transition-colors">{l.label}</a></li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="relative mt-12 pt-8 border-t border-white/10 flex flex-col sm:flex-row items-center justify-between gap-4 text-xs text-white/34">
      <p>&copy; {currentYear} Energierichter. Alle Rechte vorbehalten.</p>
      <p class="flex items-baseline gap-1.5">
        {company.tagline}
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" class="h-[20px] w-[20px] shrink-0 opacity-80 translate-y-[2.5px]" aria-hidden="true" title="Berlin">
          <line x1="2" y1="21" x2="22" y2="21" />
          <line x1="4" y1="21" x2="4" y2="10" />
          <line x1="7" y1="21" x2="7" y2="10" />
          <line x1="10" y1="21" x2="10" y2="10" />
          <line x1="14" y1="21" x2="14" y2="10" />
          <line x1="17" y1="21" x2="17" y2="10" />
          <line x1="20" y1="21" x2="20" y2="10" />
          <rect x="3" y="7" width="18" height="3" rx="0.5" />
          <path d="M7 7V5.5C7 5.22 7.22 5 7.5 5H16.5C16.78 5 17 5.22 17 5.5V7" />
          <path d="M12 5V2.5" />
          <circle cx="12" cy="2" r="0.75" />
          <path d="M10.5 4.5L12 3.5L13.5 4.5" />
        </svg>
      </p>
    </div>
  </div>
</footer>
