---
export interface Props {
  variant?: 'primary' | 'secondary' | 'outline' | 'ghost';
  size?: 'sm' | 'md' | 'lg';
  href?: string;
  type?: 'button' | 'submit';
  class?: string;
  fullWidth?: boolean;
}

const {
  variant = 'primary',
  size = 'md',
  href,
  type = 'button',
  class: className = '',
  fullWidth = false,
} = Astro.props;

const base = 'inline-flex items-center justify-center gap-2 font-bold uppercase tracking-[0.16em] transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-brand-500';

const variants: Record<string, string> = {
  primary: 'border border-brand-400 bg-brand-400 text-dark-950 hover:bg-transparent hover:text-brand-300',
  secondary: 'border border-white/16 text-white/74 hover:border-brand-400/70 hover:text-brand-300',
  outline: 'border border-dark-900/20 text-dark-900 hover:border-brand-500 hover:text-brand-700',
  ghost: 'text-dark-700 hover:text-brand-700',
};

const sizes: Record<string, string> = {
  sm: 'px-5 py-2.5 text-[0.68rem]',
  md: 'px-6 py-3 text-[0.70rem]',
  lg: 'px-8 py-4 text-[0.72rem]',
};

const classes = [base, variants[variant], sizes[size], fullWidth ? 'w-full' : '', className].join(' ');
---

{href ? (
  <a href={href} class={classes}>
    <slot />
  </a>
) : (
  <button type={type} class={classes}>
    <slot />
  </button>
)}
