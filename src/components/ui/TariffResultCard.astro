---
// Reusable TariffResultCard showing sample analysis results
---

<div class="relative w-full max-w-sm border border-white/10 bg-[#0e1720]/95 p-5 shadow-[0_24px_80px_rgba(0,0,0,0.50)] sm:p-6">
  <!-- Card header -->
  <div class="flex items-start justify-between gap-4 border-b border-white/10 pb-4">
    <div>
      <p class="text-[0.64rem] font-semibold uppercase tracking-[0.24em] text-brand-300/80">Analysebericht</p>
      <p class="mt-1.5 text-xs text-white/46">Tarifprüfung Strom & Gas</p>
    </div>
    <span class="border border-brand-400/30 px-2.5 py-1 text-[0.6rem] font-semibold uppercase tracking-[0.18em] text-brand-300 shrink-0">Unabhängig</span>
  </div>

  <!-- Savings number -->
  <div class="py-6">
    <p class="text-[0.62rem] font-semibold uppercase tracking-[0.22em] text-white/34">Mögliches Einsparpotenzial pro Jahr (Beispiel)</p>
    <p class="mt-2.5 font-heading text-5xl font-semibold leading-none text-brand-300 sm:text-6xl">420 €</p>
  </div>

  <!-- Row details -->
  <div class="space-y-3 border-y border-white/10 py-4 text-sm">
    <div class="flex items-center justify-between gap-4">
      <span class="text-white/40 text-xs">Empfehlung</span>
      <span class="font-semibold text-white text-xs">Wechsel prüfen</span>
    </div>
    <div class="flex items-center justify-between gap-4">
      <span class="text-white/40 text-xs">Status</span>
      <span class="font-semibold text-brand-300 text-xs">Unabhängig geprüft</span>
    </div>
    <div class="flex items-center justify-between gap-4">
      <span class="text-white/40 text-xs">Servicekosten</span>
      <span class="font-semibold text-white text-xs">0 €</span>
    </div>
  </div>

  <!-- 3-stat mini grid -->
  <div class="mt-4 grid grid-cols-3 gap-2">
    <div class="border border-white/10 p-3">
      <p class="font-heading text-2xl font-semibold text-white">100+</p>
      <p class="mt-0.5 text-[0.58rem] uppercase tracking-[0.14em] text-white/32">Anbieter</p>
    </div>
    <div class="border border-white/10 p-3">
      <p class="font-heading text-2xl font-semibold text-white">24h</p>
      <p class="mt-0.5 text-[0.58rem] uppercase tracking-[0.14em] text-white/32">Prüfung</p>
    </div>
    <div class="border border-white/10 p-3">
      <p class="font-heading text-2xl font-semibold text-white">0%</p>
      <p class="mt-0.5 text-[0.58rem] uppercase tracking-[0.14em] text-white/32">Bindung</p>
    </div>
  </div>
</div>
