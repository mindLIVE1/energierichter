---
export interface Props {
  title: string;
  subtitle?: string;
  label?: string;
  centered?: boolean;
  light?: boolean;
}

const {
  title,
  subtitle,
  label,
  centered = false,
  light = false,
} = Astro.props;
---

{centered ? (
  <div class="mb-14 text-center">
    {label && (
      <p class={`mb-4 label-editorial ${light ? 'text-brand-300' : 'text-brand-700'}`}>{label}</p>
    )}
    <h2 class={`max-w-3xl mx-auto font-heading text-4xl font-semibold leading-[1.03] sm:text-5xl lg:text-6xl ${light ? 'text-white' : 'text-dark-900'}`}>
      {title}
    </h2>
    {subtitle && (
      <p class={`mt-5 max-w-2xl mx-auto text-base leading-8 ${light ? 'text-white/56' : 'text-dark-700'}`}>
        {subtitle}
      </p>
    )}
  </div>
) : (
  <div class="mb-14 grid gap-8 lg:grid-cols-[0.82fr_1.18fr] lg:items-end">
    <div>
      {label && (
        <p class={`mb-4 label-editorial ${light ? 'text-brand-300' : 'text-brand-700'}`}>{label}</p>
      )}
      <h2 class={`max-w-xl font-heading text-4xl font-semibold leading-[1.03] sm:text-5xl lg:text-6xl ${light ? 'text-white' : 'text-dark-900'}`}>
        {title}
      </h2>
    </div>
    {subtitle && (
      <p class={`max-w-2xl text-base leading-8 lg:justify-self-end ${light ? 'text-white/56' : 'text-dark-700'}`}>
        {subtitle}
      </p>
    )}
  </div>
)}
