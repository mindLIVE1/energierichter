---
export interface Props {
  text: string;
  description?: string;
  ctaText?: string;
  ctaHref?: string;
  label?: string;
  secondaryCtaText?: string;
  secondaryCtaHref?: string;
}

const {
  text,
  description,
  ctaText = 'Jetzt anfragen',
  ctaHref = '/anfrage',
  label = 'Nächster Schritt',
  secondaryCtaText,
  secondaryCtaHref,
} = Astro.props;
---

<section class="bg-dark-900 border-y border-brand-400/20 py-16 sm:py-20" data-section="CtaBanner">
  <div class="container-wide flex flex-col items-start justify-between gap-8 sm:flex-row sm:items-center">
    <div>
      <p class="mb-4 label-editorial text-brand-300">{label}</p>
      <p class="max-w-2xl font-heading text-3xl font-semibold leading-[1.04] text-white sm:text-4xl lg:text-5xl">
        {text}
      </p>
      {description && (
        <p class="mt-4 max-w-xl text-sm leading-7 text-white/50">
          {description}
        </p>
      )}
    </div>
    {secondaryCtaText && secondaryCtaHref ? (
      <div class="flex flex-col gap-3 shrink-0 w-full sm:w-auto">
        <a href={ctaHref} class="inline-flex items-center justify-center gap-2 border border-brand-400 bg-brand-400 px-8 py-4 text-[0.72rem] font-bold uppercase tracking-[0.16em] text-dark-950 hover:bg-transparent hover:text-brand-300 transition-all duration-200">
          {ctaText}
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.3" stroke-linecap="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
        <a href={secondaryCtaHref} class="text-center text-[0.68rem] font-medium uppercase tracking-[0.16em] text-white/40 hover:text-brand-300 transition-colors duration-200">
          {secondaryCtaText}
        </a>
      </div>
    ) : (
      <a href={ctaHref} class="inline-flex shrink-0 items-center justify-center gap-2 border border-brand-400 bg-brand-400 px-8 py-4 text-[0.72rem] font-bold uppercase tracking-[0.16em] text-dark-950 hover:bg-transparent hover:text-brand-300 transition-all duration-200">
        {ctaText}
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.3" stroke-linecap="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    )}
  </div>
</section>

