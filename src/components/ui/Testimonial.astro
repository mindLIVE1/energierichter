---
export interface Props {
  quote: string;
  name: string;
  role?: string;
  rating?: number;
}

const {
  quote,
  name,
  role,
  rating = 5,
} = Astro.props;
---

<figure class="card-editorial p-7 sm:p-9">
  <div class="mb-6 flex gap-1 text-brand-500" aria-label={`${rating} von 5 Sternen`}>
    {Array.from({ length: 5 }).map((_, i) => (
      <svg class={`h-3.5 w-3.5 ${i < rating ? 'opacity-100' : 'opacity-20'}`} fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
        <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
      </svg>
    ))}
  </div>
  <blockquote class="text-base leading-8 text-dark-700">&ldquo;{quote}&rdquo;</blockquote>
  <figcaption class="mt-7 border-t border-dark-900/10 pt-5">
    <p class="font-semibold text-dark-900">{name}</p>
    {role && <p class="mt-1 text-xs uppercase tracking-[0.16em] text-dark-700">{role}</p>}
  </figcaption>
</figure>
