---
export interface Props {
  title: string;
  subtitle?: string;
  ctaText?: string;
  ctaHref?: string;
  secondaryCtaText?: string;
  secondaryCtaHref?: string;
  badge?: string;
  showCta?: boolean;
  bgImage?: string;
}

const {
  title,
  subtitle,
  ctaText,
  ctaHref = '/anfrage',
  secondaryCtaText,
  secondaryCtaHref,
  badge,
  showCta = ctaText !== undefined,
  bgImage,
} = Astro.props;

const hasHeroImage = Astro.slots.has('hero-image');
---

<section class="relative overflow-hidden bg-dark-900 text-white">
  {bgImage ? (
    <div class="absolute inset-0">
      <img
        src={bgImage}
        alt=""
        role="presentation"
        class="absolute inset-0 w-full h-full object-cover object-[center_30%]"
        loading="eager"
        fetchpriority="high"
      />
      <!-- Dark overlay — heavier on the left for text readability, lighter on the right to reveal image -->
      <div class="absolute inset-0" style="background: linear-gradient(105deg, rgba(6,9,13,0.92) 0%, rgba(6,9,13,0.85) 35%, rgba(6,9,13,0.6) 55%, rgba(6,9,13,0.35) 75%, rgba(6,9,13,0.25) 100%);"></div>
      <!-- Top edge fade for seamless header blend -->
      <div class="absolute inset-x-0 top-0 h-24 pointer-events-none" style="background: linear-gradient(to bottom, rgba(6,9,13,0.95), transparent);"></div>
      <!-- Bottom edge fade -->
      <div class="absolute inset-x-0 bottom-0 h-24 pointer-events-none" style="background: linear-gradient(to top, rgba(6,9,13,0.95), transparent);"></div>
    </div>
  ) : (
    <>
      <!-- Subtle grid overlay -->
      <div class="absolute inset-0 opacity-[0.055] pointer-events-none" style="background-image: linear-gradient(90deg, #ffffff 1px, transparent 1px), linear-gradient(#ffffff 1px, transparent 1px); background-size: 96px 96px;"></div>
      <div class="absolute inset-x-0 bottom-0 h-px bg-brand-400/30"></div>
    </>
  )}

  <div class={`relative container-wide py-20 sm:py-24 lg:py-28 ${hasHeroImage ? 'grid grid-cols-1 lg:grid-cols-2 gap-14 lg:gap-20 items-center' : ''}`}>
    <div class={hasHeroImage ? '' : 'max-w-3xl'}>
      {badge && (
        <p class="mb-5 label-editorial text-brand-300/90">
          {badge}
        </p>
      )}

      <h1 class="max-w-4xl font-heading text-4xl font-semibold leading-[1.05] text-white sm:text-5xl lg:text-6xl xl:text-7xl">
        <Fragment set:html={title} />
      </h1>

      {subtitle && (
        <p class="mt-7 max-w-2xl text-base sm:text-lg leading-8 text-white/66">
          {subtitle}
        </p>
      )}

      {showCta && (
        <div class="mt-10 flex flex-col sm:flex-row gap-4">
          <a href={ctaHref}
             class="inline-flex items-center justify-center gap-2 border border-brand-400 bg-brand-400 px-8 py-4 text-[0.72rem] font-bold uppercase tracking-[0.16em] text-dark-950 transition-all duration-200 hover:bg-transparent hover:text-brand-300">
            {ctaText || 'Jetzt anfragen'}
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.3" stroke-linecap="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
          {secondaryCtaText && secondaryCtaHref && (
            <a href={secondaryCtaHref}
               class="inline-flex items-center justify-center border border-white/16 px-8 py-4 text-[0.72rem] font-bold uppercase tracking-[0.16em] text-white/74 transition-all duration-200 hover:border-brand-400/70 hover:text-brand-300">
              {secondaryCtaText}
            </a>
          )}
        </div>
      )}
    </div>

    {hasHeroImage && (
      <div class="hidden lg:block">
        <div class="relative">
          <div class="absolute -inset-8 bg-brand-400/5 blur-3xl"></div>
          <div class="relative border border-white/12 bg-[#111820]/92 shadow-[0_32px_90px_rgba(0,0,0,0.42)] overflow-hidden">
            <slot name="hero-image" />
          </div>
        </div>
      </div>
    )}
  </div>
</section>
