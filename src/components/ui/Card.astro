---
export interface Props {
  title?: string;
  icon?: string;
  class?: string;
  index?: number;
}

const {
  title,
  icon,
  class: className = '',
  index,
} = Astro.props;
---

<div class={`card-editorial p-7 sm:p-9 transition-colors duration-200 hover:bg-[#f7f3ea]/60 ${className}`}>
  {(icon || typeof index === 'number') && (
    <div class="mb-6">
      {typeof index === 'number' ? (
        <p class="font-heading text-5xl font-semibold leading-none text-brand-500/70">{String(index).padStart(2, '0')}</p>
      ) : (
        <span class="text-2xl">{icon}</span>
      )}
    </div>
  )}
  {title && (
    <h3 class="text-lg font-heading font-semibold text-dark-900 mb-3">{title}</h3>
  )}
  <div class="text-sm leading-7 text-dark-700">
    <slot />
  </div>
</div>
