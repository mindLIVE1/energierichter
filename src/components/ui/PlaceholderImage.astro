---
interface Props {
  text?: string;
  aspectRatio?: string;
  class?: string;
}

const { text = "Bild Platzhalter", aspectRatio = "aspect-video", class: className } = Astro.props;
---

<div class={`relative overflow-hidden bg-[#f0ece3] flex items-center justify-center border border-dark-900/12 group transition-all duration-300 hover:bg-[#eae5d9] ${aspectRatio} ${className}`}>
  <div class="flex flex-col items-center gap-3 text-center px-6 relative z-10">
    <div class="w-12 h-12 border border-dark-900/12 bg-white flex items-center justify-center text-dark-700/30 group-hover:text-brand-500 transition-all duration-300">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <rect x="3" y="3" width="18" height="18" rx="0" ry="0"/>
        <circle cx="8.5" cy="8.5" r="1.5"/>
        <polyline points="21 15 16 10 5 21"/>
      </svg>
    </div>
    <p class="text-[0.64rem] font-semibold tracking-[0.18em] uppercase text-dark-700/40 group-hover:text-brand-700 transition-colors duration-300">
      {text}
    </p>
  </div>
  
  <!-- Grid pattern background -->
  <div class="absolute inset-0 opacity-[0.04] pointer-events-none" style="background-image: linear-gradient(90deg, #000 1px, transparent 1px), linear-gradient(#000 1px, transparent 1px); background-size: 32px 32px;"></div>
</div>
