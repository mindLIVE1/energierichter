---
import zielgruppen from '../data/zielgruppen.json';

const enableBlog = import.meta.env.PUBLIC_ENABLE_BLOG === 'true';
const enableReferenzen = import.meta.env.PUBLIC_ENABLE_REFERENZEN === 'true';
const enableZielgruppen = import.meta.env.PUBLIC_ENABLE_ZIELGRUPPEN === 'true';
const enableLeistungen = import.meta.env.PUBLIC_ENABLE_LEISTUNGEN === 'true';
const enableTransparenz = import.meta.env.PUBLIC_ENABLE_TRANSPARENZ === 'true';

const navLinks = [
  { label: 'Startseite', href: '/' },
  enableLeistungen && { label: 'Leistungen', href: '/leistungen' },
  enableZielgruppen && { label: 'Zielgruppen', href: '#', children: zielgruppen.map((z) => ({
    label: z.navLabel,
    href: `/zielgruppen/${z.slug}`,
  }))},
  enableTransparenz && { label: 'Transparenz', href: '/transparenz' },
  enableReferenzen && { label: 'Referenzen', href: '/referenzen' },
  enableBlog && { label: 'Blog', href: '/blog' },
  { label: 'Kontakt', href: '/kontakt' },
].filter(Boolean) as { label: string; href: string; children?: { label: string; href: string }[] }[];


const currentPath = Astro.url.pathname;
---

<header class="fixed top-0 inset-x-0 z-50 bg-dark-900/97 border-b border-white/8 backdrop-blur-sm transition-all duration-300" id="site-header">
  <div class="container-wide">
    <div class="flex items-center justify-between h-16 lg:h-[76px]">
      <!-- Logo -->
      <a href="/" class="flex items-center group" aria-label="Energierichter Startseite">
        <img
          src="/assets/brand/er-logo.svg"
          alt="Energierichter"
          width="1400"
          height="650"
          class="h-8 lg:h-9 w-auto opacity-95 transition-all duration-200 group-hover:opacity-80"
        />
      </a>

      <!-- Desktop Nav -->
      <nav class="hidden lg:flex items-center gap-8" aria-label="Hauptnavigation">
        {navLinks.map((link) => (
          link.children ? (
            <div class="relative group">
              <button class={`relative py-2 text-[0.72rem] font-semibold uppercase tracking-[0.15em] transition-colors duration-200 hover:text-brand-400 ${currentPath.startsWith('/zielgruppen') ? 'text-brand-400' : 'text-white/80'}`}>
                {link.label}
                <svg class="inline-block ml-1.5 w-3 h-3 transition-transform duration-200 group-hover:rotate-180" fill="none" viewBox="0 0 10 6"><path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
                {currentPath.startsWith('/zielgruppen') && <span class="absolute left-0 -bottom-[1px] h-[2px] w-full bg-brand-400" />}
              </button>
              <div class="absolute top-full left-1/2 -translate-x-1/2 pt-3 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200">
                <div class="bg-dark-950 shadow-[0_16px_48px_rgba(0,0,0,0.5)] border border-white/10 rounded py-2 min-w-[240px]">
                  {link.children.map((child) => (
                    <a href={child.href} class={`group/item flex items-center gap-3 px-5 py-3 text-[0.82rem] tracking-wide transition-all duration-150 hover:bg-white/[0.04] ${currentPath === child.href ? 'text-brand-400 font-medium' : 'text-white/75 hover:text-white'}`}>
                      <span class={`inline-block w-[3px] h-4 rounded-full transition-all duration-150 ${currentPath === child.href ? 'bg-brand-400' : 'bg-transparent group-hover/item:bg-brand-400/50'}`}></span>
                      {child.label}
                    </a>
                  ))}
                </div>
              </div>
            </div>
          ) : (
            <a href={link.href} class={`relative py-2 text-[0.72rem] font-semibold uppercase tracking-[0.15em] transition-colors duration-200 hover:text-brand-400 ${currentPath === link.href ? 'text-brand-400' : 'text-white/80'}`}>
              {link.label}
              {currentPath === link.href && <span class="absolute left-0 -bottom-[1px] h-[2px] w-full bg-brand-400" />}
            </a>
          )
        ))}
      </nav>

      <!-- CTA + Mobile Toggle -->
      <div class="flex items-center gap-4">
        <a href="/anfrage"
           class="hidden sm:inline-flex items-center gap-2 border border-brand-400/60 px-5 py-2.5 text-[0.7rem] font-bold uppercase tracking-[0.15em] text-brand-400 hover:bg-brand-400 hover:text-dark-950 transition-all duration-200">
          Jetzt anfragen
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
        <button id="mobile-toggle" class="lg:hidden p-2 border border-white/15 text-white/90 hover:border-brand-400/60 hover:text-brand-400 transition-colors duration-200" aria-label="Menü öffnen" aria-expanded="false">
          <svg id="icon-menu" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
            <path d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
          <svg id="icon-close" class="hidden" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
            <path d="M18 6L6 18M6 6l12 12"/>
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="lg:hidden fixed inset-0 top-16 bg-dark-900/98 backdrop-blur-sm z-40 translate-x-full transition-transform duration-300 ease-in-out">
    <nav class="container-wide py-8 space-y-1" aria-label="Mobile Navigation">
      {navLinks.map((link) => (
        link.children ? (
          <div class="mb-2">
            <p class="px-4 py-2.5 text-[0.7rem] font-semibold text-brand-400 uppercase tracking-[0.16em]">{link.label}</p>
            {link.children.map((child) => (
              <a href={child.href} class={`flex items-center gap-3 px-4 py-3.5 text-[0.95rem] font-medium transition-colors duration-150 ${currentPath === child.href ? 'text-brand-400' : 'text-white/80 hover:text-brand-400'}`}>
                <span class={`inline-block w-[3px] h-4 rounded-full ${currentPath === child.href ? 'bg-brand-400' : 'bg-transparent'}`}></span>
                {child.label}
              </a>
            ))}
          </div>
        ) : (
          <a href={link.href} class={`block px-4 py-3.5 text-[0.95rem] font-medium transition-colors duration-150 ${currentPath === link.href ? 'text-brand-400' : 'text-white/80 hover:text-brand-400'}`}>
            {link.label}
          </a>
        )
      ))}
      <div class="pt-6 px-4">
        <a href="/anfrage" class="flex items-center justify-center gap-2 w-full border border-brand-400/60 px-6 py-3.5 text-[0.72rem] font-bold uppercase tracking-[0.15em] text-brand-400 hover:bg-brand-400 hover:text-dark-950 transition-all duration-200">
          Jetzt anfragen
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>
    </nav>
  </div>
</header>

<!-- Spacer for fixed header -->
<div class="h-16 lg:h-[76px] bg-dark-900"></div>

<script>
  // Mobile menu toggle
  const toggle = document.getElementById('mobile-toggle');
  const menu = document.getElementById('mobile-menu');
  const iconMenu = document.getElementById('icon-menu');
  const iconClose = document.getElementById('icon-close');

  toggle?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('translate-x-full');
    menu?.classList.toggle('translate-x-full', isOpen);
    menu?.classList.toggle('translate-x-0', !isOpen);
    iconMenu?.classList.toggle('hidden', !isOpen);
    iconClose?.classList.toggle('hidden', isOpen);
    toggle.setAttribute('aria-expanded', String(!isOpen));
    document.body.style.overflow = isOpen ? '' : 'hidden';
  });

  // Sticky header depth
  const header = document.getElementById('site-header');
  const onScroll = () => {
    if (window.scrollY > 20) {
      header?.classList.add('shadow-[0_16px_40px_rgba(0,0,0,0.2)]');
    } else {
      header?.classList.remove('shadow-[0_16px_40px_rgba(0,0,0,0.2)]');
    }
  };
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();
</script>
