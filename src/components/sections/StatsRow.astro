---
export interface StatItem {
  value?: string;
  label: string;
}

export interface Props {
  items: StatItem[];
  bgColor?: string;
}

const {
  items,
  bgColor = 'bg-[#0f1a24] border-b border-white/8',
} = Astro.props;
---

<section class={`relative ${bgColor}`} data-section="StatsRow">
  <div class="container-wide">
    <div class="grid grid-cols-2 lg:grid-cols-4 divide-x-0 divide-y divide-white/10 lg:divide-x lg:divide-y-0">
      {items.map((stat, i) => (
        <div class="py-7 lg:px-7">
          <p class="font-heading text-4xl font-semibold leading-none text-brand-300">
            {stat.value !== undefined ? stat.value : String(i + 1).padStart(2, '0')}
          </p>
          <p class="mt-3 text-[0.72rem] font-semibold uppercase tracking-[0.17em] text-white/60">
            {stat.label}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
