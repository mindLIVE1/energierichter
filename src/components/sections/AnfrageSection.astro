---
import ContactForm from '../ContactForm.astro';
import company from '../../data/company.json';
---

<section class="relative bg-[#f7f3ea] py-20 sm:py-24 lg:py-32" data-section="AnfrageSection">
  <div class="container-narrow">
    <div class="grid grid-cols-1 lg:grid-cols-[1.4fr_0.6fr] gap-16">
      <!-- Form -->
      <div>
        <ContactForm showUpload={true} />
      </div>

      <!-- Sidebar -->
      <div class="space-y-8">
        <div class="card-editorial-dark p-7 text-white">
          <p class="label-editorial text-brand-300 mb-5">Warum Energierichter?</p>
          <ul class="space-y-4 text-sm">
            <li class="flex items-center gap-4 text-white/80">
              <span class="h-px w-6 bg-brand-400"></span>
              100% kostenlos für Sie
            </li>
            <li class="flex items-center gap-4 text-white/80">
              <span class="h-px w-6 bg-brand-400"></span>
              Unabhängiger Vergleich
            </li>
            <li class="flex items-center gap-4 text-white/80">
              <span class="h-px w-6 bg-brand-400"></span>
              Antwort innerhalb 24h
            </li>
            <li class="flex items-center gap-4 text-white/80">
              <span class="h-px w-6 bg-brand-400"></span>
              Datenschutz nach DSGVO
            </li>
          </ul>
        </div>

        <div class="card-editorial p-7">
          <p class="label-editorial text-brand-700 mb-5">Direkt kontaktieren</p>
          <div class="space-y-4 text-sm text-dark-700">
            <div class="flex items-center gap-3">
              <svg class="w-4 h-4 text-brand-600 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 01-2.18 2A19.86 19.86 0 013.09 5.18 2 2 0 015.11 3h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 11.91a16 16 0 006 6l2.27-2.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
              {company.phone}
            </div>
            <div class="flex items-center gap-3">
              <svg class="w-4 h-4 text-brand-600 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><path d="M22 6l-10 7L2 6"/></svg>
              {company.email}
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
