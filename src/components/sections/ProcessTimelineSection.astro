---
export interface TimelineItem {
  number?: string;
  title: string;
  description: string;
}

export interface Props {
  label?: string;
  title?: string;
  subtitle?: string;
  items: TimelineItem[];
  sectionClass?: string;
}

const {
  label,
  title,
  subtitle,
  items,
  sectionClass = 'py-20 sm:py-24 lg:py-32',
} = Astro.props;

// Precision-engineered, technical icons
const icons = [
  // Icon 1 (Data/Document input)
  `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="square" stroke-linejoin="miter"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>`,
  // Icon 2 (Analysis/Grid)
  `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="square" stroke-linejoin="miter"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="9" y1="21" x2="9" y2="9"/></svg>`,
  // Icon 3 (Optimization/Chart)
  `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="square" stroke-linejoin="miter"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg>`,
  // Icon 4 (Execution/Check)
  `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="square" stroke-linejoin="miter"><polyline points="20 6 9 17 4 12"/></svg>`,
];

const gridColsClass = items.length === 3 ? 'lg:grid-cols-3' : 'lg:grid-cols-4';
---

<section class={`bg-[#0b0f14] text-white relative overflow-hidden ${sectionClass}`} data-section="ProcessTimelineSection">
  <!-- Engineered grid background -->
  <div class="absolute inset-0 opacity-[0.02] pointer-events-none flex justify-center">
    <div class="w-full max-w-[1400px] h-full border-x border-white flex justify-between">
      <div class="w-px h-full bg-white"></div>
      <div class="w-px h-full bg-white"></div>
      <div class="w-px h-full bg-white"></div>
    </div>
  </div>

  <div class="container-wide relative z-10">
    <div class="mb-20 flex flex-col md:flex-row md:items-end justify-between gap-8 border-b border-white/10 pb-12">
      <div class="max-w-2xl">
        {label && <p class="mb-4 text-[0.65rem] font-semibold text-brand-400 uppercase tracking-[0.2em]">{label}</p>}
        {title && <h2 class="text-4xl sm:text-5xl lg:text-6xl font-heading font-semibold text-white leading-[1.05] tracking-tight">{title}</h2>}
      </div>
      {subtitle && (
        <div class="max-w-md md:text-right">
          <p class="text-white/60 text-sm sm:text-base leading-relaxed">{subtitle}</p>
        </div>
      )}
    </div>

    <!-- Technical Timeline Grid -->
    <div class="relative">
      <div class={`grid grid-cols-1 md:grid-cols-2 ${gridColsClass} gap-y-16 gap-x-8 lg:gap-x-12 relative z-10`}>
        {items.map((item, index) => (
          <div class="relative group flex flex-col">
            <!-- Connecting line (drawn from current item to the next) -->
            <div class="hidden lg:block absolute top-[1.25rem] left-[2.5rem] w-full h-px bg-white/10 group-last:hidden"></div>
            
            <!-- Icon/Number Node -->
            <div class="relative mb-8 flex items-center">
              <div class="relative flex h-10 w-10 items-center justify-center bg-dark-900 border border-white/20 group-hover:border-brand-400 transition-colors duration-300 z-10 shadow-[0_0_15px_rgba(0,0,0,0.5)]">
                <!-- Inner technical accent -->
                <div class="absolute top-0 left-0 w-1.5 h-1.5 border-t border-l border-brand-400 opacity-0 group-hover:opacity-100 transition-opacity"></div>
                <div class="absolute bottom-0 right-0 w-1.5 h-1.5 border-b border-r border-brand-400 opacity-0 group-hover:opacity-100 transition-opacity"></div>
                
                <div class="text-brand-300 opacity-80 group-hover:opacity-100 group-hover:scale-105 transition-all duration-300" set:html={icons[index % icons.length]} />
              </div>
              
              <span class="ml-5 text-[0.7rem] font-mono text-brand-400 uppercase tracking-widest border-b border-brand-400/30 pb-0.5">
                Schritt {item.number || String(index + 1).padStart(2, '0')}
              </span>
            </div>
            
            <h3 class="text-xl font-heading font-semibold text-white mb-3 group-hover:text-brand-300 transition-colors duration-300">{item.title}</h3>
            <p class="text-white/50 text-[0.9rem] leading-relaxed max-w-[90%]">{item.description}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
