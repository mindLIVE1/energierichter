---
// StromGasCompare – Strom vs. Gas comparison cards
// Accent colors: Strom=#70a37f (green), Gas=#0fbfdd (blue)
---

<section class="relative bg-dark-900 py-20 sm:py-24 lg:py-32 overflow-hidden" data-section="StromGasCompare">
  <!-- Subtle grid texture -->
  <div class="absolute inset-0 opacity-[0.035] pointer-events-none" style="background-image: linear-gradient(90deg, #ffffff 1px, transparent 1px), linear-gradient(#ffffff 1px, transparent 1px); background-size: 96px 96px;"></div>

  <div class="container-wide relative">
    <!-- Section header -->
    <div class="mb-14 max-w-2xl">
      <p class="mb-4 text-[0.68rem] font-semibold uppercase tracking-[0.24em] text-white/40">Unsere Tarifbereiche</p>
      <h2 class="font-heading text-4xl font-semibold leading-[1.05] text-white sm:text-5xl">
        Strom & Gas — unabhängig geprüft.
      </h2>
      <p class="mt-5 text-base leading-8 text-white/55">
        Ob Strom oder Gas: Wir analysieren Ihren aktuellen Vertrag, vergleichen die besten Optionen und begleiten den Wechsel — persönlich und transparent.
      </p>
    </div>

    <!-- Card grid -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">

      <!-- Card: Strom -->
      <div class="group relative border border-white/10 bg-[#0e1720]/80 transition-all duration-300 ease-out hover:-translate-y-1.5 hover:shadow-[0_10px_30px_rgba(112,163,127,0.15)]" style="border-top: 4px solid #70a37f;">
        <div class="p-8 sm:p-10">
          <!-- Icon + Badge -->
          <div class="flex items-start justify-between mb-8">
            <div class="flex items-center justify-center w-14 h-14 border border-white/10 bg-white/[0.03]">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#70a37f" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/>
              </svg>
            </div>
            <span class="inline-flex items-center border px-3 py-1.5 text-[0.6rem] font-semibold uppercase tracking-[0.18em]" style="border-color: rgba(112,163,127,0.35); color: #70a37f;">Stromtarife</span>
          </div>

          <!-- Heading -->
          <h3 class="font-heading text-2xl font-semibold text-white sm:text-3xl">Strom</h3>
          <p class="mt-3 text-[0.95rem] leading-7 text-white/55">
            Wir prüfen Ihren aktuellen Stromvertrag und finden den passenden Tarif — ob Haushalt, Gewerbe oder Wärmepumpe.
          </p>

          <!-- Feature list -->
          <ul class="mt-8 space-y-3">
            <li class="flex items-center gap-3 text-[0.82rem] text-white/60">
              <span class="inline-block w-[3px] h-3.5 rounded-full shrink-0" style="background: #70a37f;"></span>
              Haushaltsstrom & Gewerbestrom
            </li>
            <li class="flex items-center gap-3 text-[0.82rem] text-white/60">
              <span class="inline-block w-[3px] h-3.5 rounded-full shrink-0" style="background: #70a37f;"></span>
              Wärmepumpentarife
            </li>
            <li class="flex items-center gap-3 text-[0.82rem] text-white/60">
              <span class="inline-block w-[3px] h-3.5 rounded-full shrink-0" style="background: #70a37f;"></span>
              Nachtstrom & Speicherheizung
            </li>
            <li class="flex items-center gap-3 text-[0.82rem] text-white/60">
              <span class="inline-block w-[3px] h-3.5 rounded-full shrink-0" style="background: #70a37f;"></span>
              Ökostrom-Optionen
            </li>
          </ul>

          <!-- CTA -->
          <div class="mt-10">
            <a href="/anfrage" class="inline-flex items-center gap-2 text-[0.72rem] font-bold uppercase tracking-[0.16em] transition-colors duration-200 hover:opacity-80" style="color: #70a37f;">
              Stromtarif prüfen lassen
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
          </div>
        </div>
      </div>

      <!-- Card: Gas -->
      <div class="group relative border border-white/10 bg-[#0e1720]/80 transition-all duration-300 ease-out hover:-translate-y-1.5 hover:shadow-[0_10px_30px_rgba(15,191,221,0.15)]" style="border-top: 4px solid #0fbfdd;">
        <div class="p-8 sm:p-10">
          <!-- Icon + Badge -->
          <div class="flex items-start justify-between mb-8">
            <div class="flex items-center justify-center w-14 h-14 border border-white/10 bg-white/[0.03]">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#0fbfdd" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 22c-4-3-8-7.5-8-12a8 8 0 0 1 16 0c0 4.5-4 9-8 12z"/>
                <path d="M12 17c-1.5-1.5-3-3.5-3-5.5a3 3 0 0 1 6 0c0 2-1.5 4-3 5.5z"/>
              </svg>
            </div>
            <span class="inline-flex items-center border px-3 py-1.5 text-[0.6rem] font-semibold uppercase tracking-[0.18em]" style="border-color: rgba(15,191,221,0.35); color: #0fbfdd;">Gastarife</span>
          </div>

          <!-- Heading -->
          <h3 class="font-heading text-2xl font-semibold text-white sm:text-3xl">Gas</h3>
          <p class="mt-3 text-[0.95rem] leading-7 text-white/55">
            Gaspreise schwanken stark — wir finden den passenden Tarif für Heizung, Warmwasser oder gewerblichen Verbrauch.
          </p>

          <!-- Feature list -->
          <ul class="mt-8 space-y-3">
            <li class="flex items-center gap-3 text-[0.82rem] text-white/60">
              <span class="inline-block w-[3px] h-3.5 rounded-full shrink-0" style="background: #0fbfdd;"></span>
              Erdgas für Heizung & Warmwasser
            </li>
            <li class="flex items-center gap-3 text-[0.82rem] text-white/60">
              <span class="inline-block w-[3px] h-3.5 rounded-full shrink-0" style="background: #0fbfdd;"></span>
              Gewerbe- & Industriegas
            </li>
            <li class="flex items-center gap-3 text-[0.82rem] text-white/60">
              <span class="inline-block w-[3px] h-3.5 rounded-full shrink-0" style="background: #0fbfdd;"></span>
              Biogas & Klimatarife
            </li>
            <li class="flex items-center gap-3 text-[0.82rem] text-white/60">
              <span class="inline-block w-[3px] h-3.5 rounded-full shrink-0" style="background: #0fbfdd;"></span>
              Preisgarantie-Optionen
            </li>
          </ul>

          <!-- CTA -->
          <div class="mt-10">
            <a href="/anfrage" class="inline-flex items-center gap-2 text-[0.72rem] font-bold uppercase tracking-[0.16em] transition-colors duration-200 hover:opacity-80" style="color: #0fbfdd;">
              Gastarif prüfen lassen
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>
