---
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<section class="relative bg-[#f7f3ea] py-20 sm:py-24 lg:py-32" data-section="BlogGridSection">
  <div class="container-wide">
    {posts.length === 0 ? (
      <p class="text-center text-dark-700/60">Noch keine Artikel vorhanden.</p>
    ) : (
      <div class="grid gap-px bg-dark-900/12 border border-dark-900/12 md:grid-cols-2 lg:grid-cols-3">
        {posts.map((post) => (
          <a href={`/blog/${post.slug}`} class="group bg-[#f7f3ea] hover:bg-[#f0ece3] transition-colors duration-200 block">
            <div class="h-48 bg-[#eae5d9] flex items-center justify-center border-b border-dark-900/12">
              <svg class="w-10 h-10 text-dark-700/20 group-hover:text-brand-500 transition-colors duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg>
            </div>
            <div class="p-7">
              <div class="flex items-center gap-2 text-xs text-dark-700/50 mb-3">
                <time datetime={post.data.pubDate.toISOString()}>
                  {post.data.pubDate.toLocaleDateString('de-DE', { day: 'numeric', month: 'long', year: 'numeric' })}
                </time>
                {post.data.author && <span>· {post.data.author}</span>}
              </div>
              <h2 class="text-lg font-heading font-semibold text-dark-900 mb-2 group-hover:text-brand-700 transition-colors">
                {post.data.title}
              </h2>
              <p class="text-sm text-dark-700 line-clamp-2">{post.data.description}</p>
              {post.data.tags.length > 0 && (
                <div class="flex flex-wrap gap-2 mt-4">
                  {post.data.tags.slice(0, 3).map((tag: string) => (
                    <span class="px-2 py-0.5 text-[0.64rem] font-semibold uppercase tracking-[0.14em] text-brand-700 border border-brand-500/30">{tag}</span>
                  ))}
                </div>
              )}
            </div>
          </a>
        ))}
      </div>
    )}
  </div>
</section>
