---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ConsentBanner from '../components/ConsentBanner.astro';
import Hero from '../components/ui/Hero.astro';
import EditorialGridSection from '../components/sections/EditorialGridSection.astro';
import CtaBanner from '../components/ui/CtaBanner.astro';
import FaqSection from '../components/sections/FaqSection.astro';

// Reusable landing page layout — each target group page uses this structure
export interface Props {
  seo: { title: string; description: string; ogImage?: string };
  hero: { badge: string; title: string; subtitle: string; bgImage?: string; };
  painPoints: { icon: string; title: string; desc: string }[];
  benefits: { icon: string; title: string; desc: string }[];
  faqs: { question: string; answer: string }[];
}

const { seo, hero, painPoints, benefits, faqs } = Astro.props;
---

<BaseLayout title={seo.title} description={seo.description} ogImage={seo.ogImage}>
  <Header slot="header" />

  <Hero
    badge={hero.badge}
    title={hero.title}
    subtitle={hero.subtitle}
    bgImage={hero.bgImage}
  />

  <EditorialGridSection
    theme="light"
    label="Ihre Herausforderungen"
    title="Probleme, die wir kennen."
    subtitle="Wir kennen die typischen Herausforderungen und haben die Lösung."
    items={painPoints.map((p, i) => ({ number: String(i + 1).padStart(2, '0'), title: p.title, description: p.desc }))}
  />

  <EditorialGridSection
    theme="dark"
    label="So profitieren Sie"
    title="Ihre Vorteile."
    subtitle="Unsere Lösungen sind auf Ihre Bedürfnisse zugeschnitten."
    items={benefits.map((b, i) => ({ number: String(i + 1).padStart(2, '0'), title: b.title, description: b.desc }))}
  />

  <CtaBanner text="Bereit, Ihre Energiekosten zu optimieren?" />

  {faqs.length > 0 && (
    <FaqSection
      items={faqs}
      title="Kurz geklärt."
      label="Häufige Fragen"
      bgColor="bg-[#f7f3ea]"
      subtitle=""
    />
  )}

  <Footer slot="footer" />
  <ConsentBanner slot="consent" />
</BaseLayout>

