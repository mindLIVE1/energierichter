---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ConsentBanner from '../components/ConsentBanner.astro';
import Hero from '../components/ui/Hero.astro';
import ContactSection from '../components/sections/ContactSection.astro';
---

<BaseLayout
  title="Kontakt – So erreichen Sie uns | Energierichter"
  description="Kontaktieren Sie uns per Telefon, E-Mail oder Formular. Unser Team ist Mo–Fr von 9–18 Uhr für Sie da."
>
  <Header slot="header" />

  <Hero
    badge="Kontakt"
    title="Sprechen Sie mit uns."
    subtitle="Wir freuen uns auf Ihre Nachricht. Unser Team ist für Sie da."
  />

  <ContactSection />

  <Footer slot="footer" />
  <ConsentBanner slot="consent" />
</BaseLayout>

