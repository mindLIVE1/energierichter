---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ConsentBanner from '../components/ConsentBanner.astro';
import ContactForm from '../components/ContactForm.astro';

import company from '../data/company.json';
---

<BaseLayout
  title="Kontakt – So erreichen Sie uns | Energierichter"
  description="Kontaktieren Sie uns per Telefon, E-Mail oder Formular. Unser Team ist Mo–Fr von 9–18 Uhr für Sie da."
>
  <Header slot="header" />

  <!-- Hero -->
  <section class="relative overflow-hidden bg-dark-900 text-white">
    <div class="absolute inset-0 opacity-[0.055] pointer-events-none" style="background-image: linear-gradient(90deg, #ffffff 1px, transparent 1px), linear-gradient(#ffffff 1px, transparent 1px); background-size: 96px 96px;"></div>
    <div class="absolute inset-x-0 bottom-0 h-px bg-brand-400/30"></div>

    <div class="relative container-wide py-20 sm:py-24 lg:py-28 max-w-3xl">
      <p class="mb-5 label-editorial text-brand-300/90">Kontakt</p>
      <h1 class="max-w-4xl font-heading text-4xl font-semibold leading-[1.05] text-white sm:text-5xl lg:text-6xl xl:text-7xl">
        Sprechen Sie mit uns.
      </h1>
      <p class="mt-7 max-w-2xl text-base sm:text-lg leading-8 text-white/66">
        Wir freuen uns auf Ihre Nachricht. Unser Team ist für Sie da.
      </p>
    </div>
  </section>

  <section class="bg-[#f7f3ea] py-20 sm:py-24 lg:py-32">
    <div class="container-wide">
      <div class="grid grid-cols-1 lg:grid-cols-[1.1fr_0.9fr] gap-16 lg:gap-20">
        <!-- Form -->
        <div>
          <p class="mb-4 label-editorial text-brand-700">Nachricht senden</p>
          <h2 class="font-heading text-3xl font-semibold text-dark-900 mb-8 sm:text-4xl">Schreiben Sie uns</h2>
          <ContactForm />
        </div>

        <!-- Contact Info -->
        <div class="space-y-10">
          <!-- Contact details -->
          <div>
            <p class="mb-4 label-editorial text-brand-700">Kontaktdaten</p>
            <h3 class="font-heading text-2xl font-semibold text-dark-900 mb-6">Direkt erreichen</h3>
            <div class="border-y border-dark-900/12">
              <div class="flex items-center gap-5 py-5 border-b border-dark-900/12">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" class="text-brand-600 shrink-0"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
                <div>
                  <p class="font-semibold text-dark-900 text-sm">Adresse</p>
                  <p class="text-sm text-dark-700">{company.address.street}, {company.address.zip} {company.address.city}</p>
                </div>
              </div>

              <div class="flex items-center gap-5 py-5 border-b border-dark-900/12">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" class="text-brand-600 shrink-0"><path d="M22 16.92v3a2 2 0 01-2.18 2A19.86 19.86 0 013.09 5.18 2 2 0 015.11 3h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 11.91a16 16 0 006 6l2.27-2.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
                <div>
                  <p class="font-semibold text-dark-900 text-sm">Telefon</p>
                  <p class="text-sm text-dark-700">{company.phone}</p>
                  <p class="text-xs text-dark-700/60">{company.hours}</p>
                </div>
              </div>

              <div class="flex items-center gap-5 py-5">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" class="text-brand-600 shrink-0"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><path d="M22 6l-10 7L2 6"/></svg>
                <div>
                  <p class="font-semibold text-dark-900 text-sm">E-Mail</p>
                  <p class="text-sm text-dark-700">{company.email}</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Map Section (consent-gated) -->
          <div class="border border-dark-900/12 overflow-hidden">

            <!-- Placeholder (visible until consent) -->
            <div data-consent-placeholder="embeds" class="bg-[#f0ece3] h-64 flex items-center justify-center p-6">
              <div class="text-center">
                <svg class="w-10 h-10 mx-auto mb-3 text-dark-700/30" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
                <p class="text-sm text-dark-700 mb-3">Um die Karte anzuzeigen, müssen externe Inhalte geladen werden.</p>
                <button data-consent-accept="embeds"
                  class="inline-flex items-center gap-2 border border-brand-400 bg-brand-400 px-5 py-2.5 text-[0.68rem] font-bold uppercase tracking-[0.16em] text-dark-950 hover:bg-transparent hover:text-brand-700 transition-all duration-200">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M5 13l4 4L19 7"/></svg>
                  Karte laden
                </button>
              </div>
            </div>

            <!-- Google Maps embed (hidden until consent) -->
            <div data-consent-embed="embeds" style="display:none;">
              <iframe
                data-consent="embeds"
                data-consent-src={company.mapsEmbed}
                width="100%"
                height="256"
                style="border:0;"
                allowfullscreen=""
                loading="lazy"
                referrerpolicy="no-referrer-when-downgrade"
                title="Standort auf Google Maps"
              ></iframe>
            </div>

          </div>
        </div>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
  <ConsentBanner slot="consent" />
</BaseLayout>
