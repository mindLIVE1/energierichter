---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ConsentBanner from '../components/ConsentBanner.astro';
import Hero from '../components/ui/Hero.astro';
import EditorialGridSection from '../components/sections/EditorialGridSection.astro';
import FeatureImageSection from '../components/sections/FeatureImageSection.astro';
import ProcessTimelineSection from '../components/sections/ProcessTimelineSection.astro';
import CtaBanner from '../components/ui/CtaBanner.astro';

import services from '../data/services.json';
import processSteps from '../data/process-steps.json';

if (import.meta.env.PUBLIC_DISABLE_LEISTUNGEN === 'true') return Astro.redirect('/');
---

<BaseLayout
  title="Unsere Leistungen – Strom & Gas Tarifvergleich | Energierichter"
  description="Tarifvergleich, Wechselservice, Verbrauchsanalyse & Vertragsüberwachung – alle Leistungen Ihres unabhängigen Energierichters im Überblick."
>
  <Header slot="header" />

  <Hero
    badge="Strom · Gas · Wärme"
    title="Unsere Leistungen"
    subtitle="Vom Tarifvergleich bis zur dauerhaften Betreuung – wir sind Ihr Partner für optimale Energiekosten."
    ctaText="Jetzt anfragen"
    ctaHref="/anfrage"
  />

  <EditorialGridSection
    theme="light"
    label="Was wir für Sie tun"
    title="Leistungsportfolio"
    subtitle="Maßgeschneidert für jeden Bedarf – von der Analyse bis zur dauerhaften Betreuung."
    items={services.all.map((s, i) => ({ number: String(i + 1).padStart(2, '0'), title: s.title, description: s.description }))}
  />

  <FeatureImageSection
    imageText="Energieberater im Gespräch mit Geschäftskunde"
    aspectRatio="aspect-[4/3]"
    label="Persönlich statt anonym"
    title="Persönliche Beratung statt anonymer Algorithmus."
    description="Hinter jeder Empfehlung steht ein erfahrener Energieberater, der Ihren Verbrauch versteht und Ihre individuellen Anforderungen berücksichtigt. Kein Chatbot, kein Standardtarif – sondern echte Beratung."
    cta={{ href: '/anfrage', text: 'Jetzt beraten lassen' }}
  />

  <ProcessTimelineSection
    label="Unser Prozess"
    title="Transparent und effizient."
    subtitle="So funktioniert die Zusammenarbeit mit Energierichter."
    items={processSteps.leistungen.map(item => ({ number: item.step, title: item.title, description: item.description }))}
    sectionClass="py-20 sm:py-24 lg:py-32"
  />

  <CtaBanner text="Lassen Sie uns gemeinsam sparen." ctaText="Kostenlose Beratung starten" ctaHref="/anfrage" label="Nächster Schritt" />

  <Footer slot="footer" />
  <ConsentBanner slot="consent" />
</BaseLayout>

