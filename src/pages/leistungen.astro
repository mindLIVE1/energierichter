---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ConsentBanner from '../components/ConsentBanner.astro';
import SectionHeading from '../components/ui/SectionHeading.astro';
import CtaBanner from '../components/ui/CtaBanner.astro';
import PlaceholderImage from '../components/ui/PlaceholderImage.astro';

import services from '../data/services.json';
import processSteps from '../data/process-steps.json';

if (import.meta.env.PUBLIC_ENABLE_LEISTUNGEN !== 'true') return Astro.redirect('/');
---

<BaseLayout
  title="Unsere Leistungen – Strom & Gas Tarifvergleich | Energierichter"
  description="Tarifvergleich, Wechselservice, Verbrauchsanalyse & Vertragsüberwachung – alle Leistungen Ihres unabhängigen Energierichters im Überblick."
>
  <Header slot="header" />

  <!-- Hero -->
  <section class="relative overflow-hidden bg-dark-900 text-white">
    <div class="absolute inset-0 opacity-[0.055] pointer-events-none" style="background-image: linear-gradient(90deg, #ffffff 1px, transparent 1px), linear-gradient(#ffffff 1px, transparent 1px); background-size: 96px 96px;"></div>
    <div class="absolute inset-x-0 bottom-0 h-px bg-brand-400/30"></div>

    <div class="relative container-wide py-20 sm:py-24 lg:py-28 max-w-3xl">
      <p class="mb-5 label-editorial text-brand-300/90">Strom · Gas · Wärme</p>
      <h1 class="max-w-4xl font-heading text-4xl font-semibold leading-[1.05] text-white sm:text-5xl lg:text-6xl xl:text-7xl">
        Unsere Leistungen
      </h1>
      <p class="mt-7 max-w-2xl text-base sm:text-lg leading-8 text-white/66">
        Vom Tarifvergleich bis zur dauerhaften Betreuung – wir sind Ihr Partner für optimale Energiekosten.
      </p>
      <div class="mt-10">
        <a href="/anfrage" class="inline-flex items-center justify-center gap-2 border border-brand-400 bg-brand-400 px-8 py-4 text-[0.72rem] font-bold uppercase tracking-[0.16em] text-dark-950 transition-all duration-200 hover:bg-transparent hover:text-brand-300">
          Jetzt anfragen
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.3" stroke-linecap="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Service Grid (editorial) -->
  <section class="bg-[#f7f3ea] py-20 sm:py-24 lg:py-32">
    <div class="container-wide">
      <SectionHeading
        label="Was wir für Sie tun"
        title="Leistungsportfolio"
        subtitle="Maßgeschneidert für jeden Bedarf – von der Analyse bis zur dauerhaften Betreuung."
      />
      <div class="grid border-y border-dark-900/12 md:grid-cols-3">
        {services.all.map((s, i) => (
          <article class={`py-10 md:min-h-80 md:px-8 ${i > 0 ? 'border-t border-dark-900/12 md:border-l md:border-t-0' : ''}`}>
            <p class="font-heading text-5xl font-semibold leading-none text-brand-500/70">{String(i + 1).padStart(2, '0')}</p>
            <h3 class="mt-12 font-heading text-2xl font-semibold leading-tight text-dark-900">{s.title}</h3>
            <p class="mt-5 text-sm leading-7 text-dark-700">{s.description}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Feature Image: Editorial break -->
  <section class="bg-white py-20 sm:py-24 lg:py-32">
    <div class="container-wide">
      <div class="grid grid-cols-1 items-center gap-12 lg:grid-cols-[0.9fr_1.1fr]">
        <PlaceholderImage text="Energieberater im Gespräch mit Geschäftskunde" aspectRatio="aspect-[4/3]" />
        <div>
          <p class="mb-5 label-editorial text-dark-700">Persönlich statt anonym</p>
          <h2 class="max-w-xl font-heading text-3xl font-semibold leading-[1.05] text-dark-900 sm:text-4xl lg:text-5xl">Persönliche Beratung statt anonymer Algorithmus.</h2>
          <p class="mt-6 max-w-2xl text-base leading-8 text-dark-700">
            Hinter jeder Empfehlung steht ein erfahrener Energieberater, der Ihren Verbrauch versteht und Ihre individuellen Anforderungen berücksichtigt. Kein Chatbot, kein Standardtarif – sondern echte Beratung.
          </p>
          <div class="mt-8">
            <a href="/anfrage" class="inline-flex items-center gap-2 border-b border-brand-500 pb-1 text-[0.72rem] font-bold uppercase tracking-[0.16em] text-dark-900 hover:text-brand-700">
              Jetzt beraten lassen
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.3" stroke-linecap="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Process (editorial numbered) -->
  <section class="relative overflow-hidden bg-[#111820] py-20 text-white sm:py-24 lg:py-32">
    <div class="absolute inset-0 opacity-[0.045] pointer-events-none" style="background-image: linear-gradient(90deg, #ffffff 1px, transparent 1px); background-size: 112px 112px;"></div>
    <div class="container-wide relative">
      <SectionHeading
        label="Unser Prozess"
        title="Transparent und effizient."
        subtitle="So funktioniert die Zusammenarbeit mit Energierichter."
        light
      />
      <div class="grid border border-white/12 lg:grid-cols-4">
        {processSteps.leistungen.map((item, i) => (
          <article class={`p-8 lg:min-h-72 ${i > 0 ? 'border-t border-white/12 lg:border-l lg:border-t-0' : ''}`}>
            <p class="font-heading text-5xl font-semibold leading-none text-brand-300/86">{item.step}</p>
            <h3 class="mt-14 font-heading text-2xl font-semibold leading-tight text-white">{item.title}</h3>
            <p class="mt-4 text-sm leading-7 text-white/52">{item.description}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <CtaBanner text="Lassen Sie uns gemeinsam sparen." ctaText="Kostenlose Beratung starten" ctaHref="/anfrage" label="Nächster Schritt" />

  <Footer slot="footer" />
  <ConsentBanner slot="consent" />
</BaseLayout>
