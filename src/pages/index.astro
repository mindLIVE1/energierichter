---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ConsentBanner from '../components/ConsentBanner.astro';

import allTestimonials from '../data/testimonials.json';
import faqs from '../data/faqs.json';
import services from '../data/services.json';
import processSteps from '../data/process-steps.json';
import stats from '../data/stats.json';

const enableStats = import.meta.env.PUBLIC_ENABLE_STATS === 'true';
const enableLeistungen = import.meta.env.PUBLIC_ENABLE_LEISTUNGEN === 'true';
const enableReferenzen = import.meta.env.PUBLIC_ENABLE_REFERENZEN === 'true';
const enableFaq = import.meta.env.PUBLIC_ENABLE_FAQ === 'true';

const testimonials = allTestimonials.slice(0, 3);

const benefitChecks = [
  'Über 100 Anbieter im Vergleich',
  'Zugang zu Sonderkonditionen',
  'Persönlicher Ansprechpartner',
];
---

<BaseLayout
  title="Energierichter – Unabhängige Energieberatung | Strom & Gas"
  description="Ihr unabhängiger Energierichter: Wir finden den besten Strom- und Gastarif für Privat- und Geschäftskunden. Kostenlos, transparent, unverbindlich."
>
  <Header slot="header" />

  <!-- Hero -->
  <section class="home-hero relative isolate overflow-hidden bg-dark-900 text-white">
    <div class="absolute inset-0 opacity-[0.18] pointer-events-none" style="background-image: linear-gradient(120deg, rgba(231,179,69,0.24) 0 1px, transparent 1px 80px), linear-gradient(90deg, rgba(255,255,255,0.08) 0 1px, transparent 1px 140px);"></div>
    <div class="absolute inset-x-0 bottom-0 h-2 bg-brand-400"></div>

    <div class="container-wide relative grid grid-cols-1 lg:grid-cols-[1.03fr_0.97fr] gap-12 lg:gap-16 items-center py-14 sm:py-16 lg:py-20">
      <div class="max-w-3xl">
        <p class="mb-5 inline-flex items-center gap-3 text-[0.72rem] font-extrabold uppercase tracking-[0.22em] text-brand-400">
          <span class="h-px w-10 bg-brand-400"></span>
          Unabhängig · Transparent · Kostenlos
        </p>

        <h1 class="max-w-4xl text-[clamp(3.05rem,11vw,7.8rem)] font-heading font-extrabold leading-[0.88] text-white">
          Energiekosten <span class="text-brand-400">intelligent</span> senken
        </h1>

        <p class="mt-7 max-w-2xl text-base sm:text-lg font-medium leading-relaxed text-white/72">
          Wir vergleichen über 100 Anbieter und finden den optimalen Strom- &amp; Gastarif für Sie – kostenlos und unverbindlich.
        </p>

        <div class="mt-9 flex flex-col sm:flex-row gap-4">
          <a href="/anfrage" class="inline-flex items-center justify-center gap-2 border border-brand-400 bg-brand-400 px-8 py-4 text-sm font-extrabold uppercase tracking-[0.14em] text-dark-950 shadow-[6px_6px_0_rgba(255,255,255,0.18)] transition-all duration-150 hover:translate-x-[2px] hover:translate-y-[2px] hover:shadow-[3px_3px_0_rgba(255,255,255,0.18)] active:translate-x-[6px] active:translate-y-[6px] active:shadow-none">
            Kostenlos anfragen
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
          <a href="/termin" class="inline-flex items-center justify-center gap-2 border border-white/28 px-8 py-4 text-sm font-extrabold uppercase tracking-[0.14em] text-white transition-colors duration-200 hover:border-brand-400 hover:text-brand-400">
            Termin vereinbaren
          </a>
        </div>

        <dl class="mt-10 grid max-w-xl grid-cols-3 border-y border-white/16 py-5 text-white">
          <div>
            <dt class="text-[0.65rem] font-extrabold uppercase tracking-[0.18em] text-white/42">Anbieter</dt>
            <dd class="mt-1 font-heading text-4xl font-extrabold text-brand-400">100+</dd>
          </div>
          <div class="border-l border-white/16 pl-5">
            <dt class="text-[0.65rem] font-extrabold uppercase tracking-[0.18em] text-white/42">Service</dt>
            <dd class="mt-1 font-heading text-4xl font-extrabold text-brand-400">0 €</dd>
          </div>
          <div class="border-l border-white/16 pl-5">
            <dt class="text-[0.65rem] font-extrabold uppercase tracking-[0.18em] text-white/42">Status</dt>
            <dd class="mt-2 text-xs font-extrabold uppercase tracking-[0.18em] text-accent-300">Unabhängig</dd>
          </div>
        </dl>
      </div>

      <div class="relative">
        <div class="absolute -right-10 -top-8 hidden h-24 w-24 border-8 border-brand-400 lg:block"></div>
        <div class="relative border-4 border-brand-400 bg-[#f7f4ec] p-5 text-dark-950 shadow-[18px_18px_0_rgba(231,179,69,0.22)] sm:p-7">
          <div class="flex items-start justify-between gap-6 border-b border-dark-900/16 pb-5">
            <img
              src="/assets/brand/energierichter-logo-horizontal-light.png"
              alt="Energierichter"
              width="1684"
              height="515"
              class="h-10 w-auto mix-blend-multiply sm:h-12"
            />
            <span class="shrink-0 border border-dark-900 px-3 py-1 text-[0.65rem] font-extrabold uppercase tracking-[0.18em]">Tarifurteil</span>
          </div>

          <div class="grid grid-cols-2 border-b border-dark-900/16 py-6">
            <div>
              <p class="text-[0.68rem] font-extrabold uppercase tracking-[0.2em] text-dark-900/48">Aktenzeichen</p>
              <p class="mt-2 font-heading text-4xl font-extrabold leading-none">ER-420</p>
            </div>
            <div class="border-l border-dark-900/16 pl-5">
              <p class="text-[0.68rem] font-extrabold uppercase tracking-[0.2em] text-dark-900/48">Empfehlung</p>
              <p class="mt-2 text-sm font-extrabold uppercase tracking-[0.18em] text-accent-500">Wechsel prüfen</p>
            </div>
          </div>

          <div class="py-6">
            <div class="mb-3 flex items-end justify-between gap-4">
              <div>
                <p class="text-[0.68rem] font-extrabold uppercase tracking-[0.2em] text-dark-900/48">Ersparnis pro Jahr</p>
                <p class="mt-1 font-heading text-7xl font-extrabold leading-none text-brand-500">420 €</p>
              </div>
              <svg class="mb-2 h-16 w-24 text-accent-400" viewBox="0 0 120 74" fill="none" aria-hidden="true">
                <path d="M4 66L34 42L55 49L84 17L116 8" stroke="currentColor" stroke-width="8" stroke-linecap="square"/>
                <path d="M92 8H116V32" stroke="currentColor" stroke-width="8" stroke-linecap="square"/>
              </svg>
            </div>
            <div class="space-y-3 text-sm font-bold">
              <div class="grid grid-cols-[1fr_auto] gap-5 border-t border-dark-900/12 pt-3">
                <span class="text-dark-900/58">Aktueller Vertrag</span>
                <span>1.920 €</span>
              </div>
              <div class="grid grid-cols-[1fr_auto] gap-5 border-t border-dark-900/12 pt-3">
                <span class="text-dark-900/58">Geprüfter Tarif</span>
                <span>1.500 €</span>
              </div>
              <div class="grid grid-cols-[1fr_auto] gap-5 border-t border-dark-900/12 pt-3 text-accent-600">
                <span>Servicekosten</span>
                <span>0 €</span>
              </div>
            </div>
          </div>

          <div class="flex items-center justify-between gap-4 bg-dark-900 px-4 py-3 text-white">
            <span class="text-[0.68rem] font-extrabold uppercase tracking-[0.2em] text-white/52">Entscheidung</span>
            <span class="font-heading text-3xl font-extrabold text-brand-400">Sparen</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Trust Badges -->
  {enableStats && (
    <section class="bg-brand-400 border-b-4 border-dark-900">
      <div class="container-wide">
        <div class="grid grid-cols-2 lg:grid-cols-4 divide-x-0 divide-y divide-dark-900/18 py-0 sm:divide-x sm:divide-y-0">
          {stats.trustBadges.map((badge, i) => (
            <div class="flex min-h-24 items-center gap-4 px-4 py-5 sm:px-6">
              <span class="font-heading text-4xl font-extrabold text-dark-950">{String(i + 1).padStart(2, '0')}</span>
              <span class="text-sm font-extrabold uppercase tracking-[0.12em] text-dark-900/78">{badge.label}</span>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Services -->
  {enableLeistungen && (
    <section class="bg-[#f7f4ec] py-16 sm:py-20 lg:py-24">
      <div class="container-wide">
        <div class="mb-10 grid gap-6 lg:grid-cols-[0.82fr_1.18fr] lg:items-end">
          <div>
            <p class="mb-3 text-[0.72rem] font-extrabold uppercase tracking-[0.22em] text-brand-600">Unsere Leistungen</p>
            <h2 class="max-w-xl font-heading text-5xl font-extrabold leading-none text-dark-950 sm:text-6xl">Tarifanalyse ohne Umwege.</h2>
          </div>
          <p class="max-w-2xl text-base font-medium leading-relaxed text-dark-900/64 lg:justify-self-end">
            Von der Tarifanalyse bis zum reibungslosen Wechsel – wir begleiten Sie durch den gesamten Prozess.
          </p>
        </div>

        <div class="grid border-y border-dark-900/18 md:grid-cols-3">
          {services.highlight.map((s, i) => (
            <article class={`group min-h-80 border-dark-900/18 py-8 md:px-7 ${i > 0 ? 'md:border-l' : ''}`}>
              <p class="font-heading text-7xl font-extrabold leading-none text-dark-950/10 transition-colors duration-300 group-hover:text-brand-400">0{i + 1}</p>
              <h3 class="mt-8 font-heading text-3xl font-extrabold leading-none text-dark-950">{s.title}</h3>
              <p class="mt-4 text-sm leading-relaxed text-dark-900/64">{s.description}</p>
            </article>
          ))}
        </div>

        <div class="mt-9">
          <a href="/leistungen" class="inline-flex items-center gap-2 border-b-2 border-brand-400 pb-1 text-sm font-extrabold uppercase tracking-[0.14em] text-dark-950 hover:text-brand-600">
            Alle Leistungen ansehen
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </div>
      </div>
    </section>
  )}

  <!-- Why Energierichter — Alternating Split Section -->
  <section class="bg-white py-16 sm:py-20 lg:py-28">
    <div class="container-wide">
      <div class="mb-12 max-w-3xl">
        <p class="mb-3 text-[0.72rem] font-extrabold uppercase tracking-[0.22em] text-accent-600">Warum Energierichter?</p>
        <h2 class="font-heading text-5xl font-extrabold leading-none text-dark-950 sm:text-6xl">Persönlich, unabhängig und immer auf Ihrer Seite.</h2>
      </div>

      <div class="grid grid-cols-1 gap-14 lg:gap-20">
        <div class="grid grid-cols-1 items-center gap-10 lg:grid-cols-[0.9fr_1.1fr]">
          <div>
            <div class="mb-5 inline-flex items-center gap-2 border border-brand-400 bg-brand-50 px-3 py-1 text-xs font-extrabold uppercase tracking-[0.14em] text-dark-950">
              100% unabhängig
            </div>
            <h3 class="max-w-xl font-heading text-4xl font-extrabold leading-none text-dark-950 sm:text-5xl">Kein Anbieter, sondern <span class="text-brand-500">Ihr Berater</span></h3>
            <p class="mt-5 max-w-2xl text-base leading-relaxed text-dark-900/66">
              Anders als Vergleichsportale sind wir nicht an bestimmte Energieversorger gebunden. Wir beraten Sie persönlich, analysieren Ihren individuellen Verbrauch und finden den Tarif, der wirklich zu Ihnen passt.
            </p>
            <ul class="mt-7 space-y-3">
              {benefitChecks.map((item) => (
                <li class="flex items-center gap-3 text-sm font-bold text-dark-900/78">
                  <span class="flex h-6 w-6 shrink-0 items-center justify-center bg-dark-900 text-brand-400">
                    <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path d="M5 13l4 4L19 7"/></svg>
                  </span>
                  {item}
                </li>
              ))}
            </ul>
          </div>

          <div class="border-2 border-dark-900 bg-[#f7f4ec] p-5 shadow-[12px_12px_0_#e7b345] sm:p-7">
            <div class="flex items-center justify-between border-b border-dark-900/14 pb-4">
              <p class="text-[0.68rem] font-extrabold uppercase tracking-[0.2em] text-dark-900/48">Prüfprotokoll</p>
              <p class="text-sm font-extrabold uppercase tracking-[0.16em] text-accent-600">neutral</p>
            </div>
            <div class="grid grid-cols-2 gap-0 border-b border-dark-900/14">
              <div class="py-8 pr-5">
                <p class="font-heading text-7xl font-extrabold leading-none text-dark-950">0</p>
                <p class="mt-2 text-xs font-extrabold uppercase tracking-[0.16em] text-dark-900/58">Anbieterbindung</p>
              </div>
              <div class="border-l border-dark-900/14 py-8 pl-5">
                <p class="font-heading text-7xl font-extrabold leading-none text-brand-500">100+</p>
                <p class="mt-2 text-xs font-extrabold uppercase tracking-[0.16em] text-dark-900/58">Tarife im Blick</p>
              </div>
            </div>
            <div class="grid gap-3 py-5 text-sm font-bold">
              <div class="grid grid-cols-[9rem_1fr] gap-4">
                <span class="text-dark-900/48">Verbrauch</span>
                <span>individuell analysiert</span>
              </div>
              <div class="grid grid-cols-[9rem_1fr] gap-4">
                <span class="text-dark-900/48">Konditionen</span>
                <span>Sondertarife berücksichtigt</span>
              </div>
              <div class="grid grid-cols-[9rem_1fr] gap-4">
                <span class="text-dark-900/48">Betreuung</span>
                <span>persönlicher Ansprechpartner</span>
              </div>
            </div>
          </div>
        </div>

        <div class="grid grid-cols-1 items-center gap-10 lg:grid-cols-[1.05fr_0.95fr]">
          <div class="order-2 border-2 border-dark-900 bg-dark-900 p-5 text-white shadow-[12px_12px_0_#70a37f] sm:p-7 lg:order-1">
            <div class="flex items-center justify-between border-b border-white/14 pb-4">
              <p class="text-[0.68rem] font-extrabold uppercase tracking-[0.2em] text-white/48">Einsparurteil</p>
              <p class="text-sm font-extrabold uppercase tracking-[0.16em] text-brand-400">kostenlos</p>
            </div>
            <div class="py-7">
              <p class="text-[0.72rem] font-extrabold uppercase tracking-[0.22em] text-white/42">Ø Ersparnis/Jahr</p>
              <p class="mt-2 font-heading text-[8rem] font-extrabold leading-[0.8] text-brand-400">420 €</p>
            </div>
            <div class="grid grid-cols-2 border-t border-white/14">
              <div class="py-5 pr-5">
                <p class="font-heading text-4xl font-extrabold text-white">100%</p>
                <p class="mt-1 text-xs font-extrabold uppercase tracking-[0.16em] text-white/48">Kostenlos für Sie</p>
              </div>
              <div class="border-l border-white/14 py-5 pl-5">
                <p class="font-heading text-4xl font-extrabold text-white">sicher</p>
                <p class="mt-1 text-xs font-extrabold uppercase tracking-[0.16em] text-white/48">Versorgung bleibt</p>
              </div>
            </div>
          </div>

          <div class="order-1 lg:order-2">
            <div class="mb-5 inline-flex items-center gap-2 border border-accent-400 bg-accent-50 px-3 py-1 text-xs font-extrabold uppercase tracking-[0.14em] text-dark-950">
              Echte Ersparnis
            </div>
            <h3 class="max-w-xl font-heading text-4xl font-extrabold leading-none text-dark-950 sm:text-5xl">Weniger zahlen, <span class="text-accent-600">mehr genießen</span></h3>
            <p class="mt-5 max-w-2xl text-base leading-relaxed text-dark-900/66">
              Unsere Kunden sparen im Durchschnitt 420 € pro Jahr – ohne Kompromisse bei der Versorgungssicherheit. Und das Beste: Unser Service ist für Sie komplett kostenlos.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section class="relative overflow-hidden bg-dark-900 py-16 text-white sm:py-20 lg:py-28">
    <div class="absolute inset-0 opacity-[0.1] pointer-events-none" style="background-image: repeating-linear-gradient(90deg, transparent 0 78px, #e7b345 78px 80px);"></div>
    <div class="container-wide relative">
      <div class="mb-12 grid gap-6 lg:grid-cols-[0.82fr_1.18fr] lg:items-end">
        <div>
          <p class="mb-3 text-[0.72rem] font-extrabold uppercase tracking-[0.22em] text-brand-400">So einfach geht's</p>
          <h2 class="max-w-xl font-heading text-5xl font-extrabold leading-none text-white sm:text-6xl">In nur 3 Schritten zum besseren Tarif.</h2>
        </div>
        <p class="max-w-2xl text-base font-medium leading-relaxed text-white/62 lg:justify-self-end">
          In nur 3 Schritten zu Ihrem optimalen Energietarif
        </p>
      </div>

      <div class="grid border border-brand-400/40 lg:grid-cols-3">
        {processSteps.homepage.map((item, i) => (
          <article class={`min-h-80 p-7 ${i > 0 ? 'border-t border-brand-400/40 lg:border-l lg:border-t-0' : ''}`}>
            <div class="flex items-start justify-between gap-5">
              <span class="font-heading text-8xl font-extrabold leading-none text-brand-400">{item.step}</span>
              <span class="mt-2 h-3 w-3 bg-accent-400"></span>
            </div>
            <h3 class="mt-12 font-heading text-3xl font-extrabold leading-none text-white">{item.title}</h3>
            <p class="mt-4 text-sm leading-relaxed text-white/58">{item.description}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Banner -->
  <section class="bg-accent-400 border-y-4 border-dark-900 py-10 sm:py-14">
    <div class="container-wide flex flex-col items-start justify-between gap-6 sm:flex-row sm:items-center">
      <p class="max-w-2xl font-heading text-4xl font-extrabold leading-none text-dark-950 sm:text-5xl">
        Bereit für niedrigere Energiekosten?
      </p>
      <a href="/anfrage" class="inline-flex shrink-0 items-center justify-center gap-2 border border-dark-900 bg-dark-900 px-8 py-4 text-sm font-extrabold uppercase tracking-[0.14em] text-white shadow-[5px_5px_0_rgba(255,255,255,0.52)] transition-all duration-150 hover:translate-x-[2px] hover:translate-y-[2px] hover:shadow-[3px_3px_0_rgba(255,255,255,0.52)] active:translate-x-[5px] active:translate-y-[5px] active:shadow-none">
        Jetzt kostenlos anfragen
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>
  </section>

  <!-- Testimonials -->
  {enableReferenzen && (
    <section class="bg-[#f7f4ec] py-16 sm:py-20 lg:py-24">
      <div class="container-wide">
        <div class="mb-10 grid gap-6 lg:grid-cols-[0.82fr_1.18fr] lg:items-end">
          <div>
            <p class="mb-3 text-[0.72rem] font-extrabold uppercase tracking-[0.22em] text-brand-600">Das sagen unsere Kunden</p>
            <h2 class="max-w-xl font-heading text-5xl font-extrabold leading-none text-dark-950 sm:text-6xl">Geprüft in der Praxis.</h2>
          </div>
          <p class="max-w-2xl text-base font-medium leading-relaxed text-dark-900/64 lg:justify-self-end">
            Überzeugen Sie sich von den Erfahrungen anderer Kunden.
          </p>
        </div>

        <div class="grid border-y border-dark-900/18 md:grid-cols-3">
          {testimonials.map((t, i) => (
            <figure class={`py-8 md:px-7 ${i > 0 ? 'md:border-l md:border-dark-900/18' : ''}`}>
              <div class="mb-5 flex gap-1 text-brand-500" aria-label={`${t.rating ?? 5} von 5 Sternen`}>
                {Array.from({ length: 5 }).map((_, star) => (
                  <svg class={`h-4 w-4 ${star < (t.rating ?? 5) ? 'opacity-100' : 'opacity-20'}`} fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                  </svg>
                ))}
              </div>
              <blockquote class="text-base font-medium leading-relaxed text-dark-900/74">&ldquo;{t.quote}&rdquo;</blockquote>
              <figcaption class="mt-6 border-t border-dark-900/12 pt-4">
                <p class="font-extrabold text-dark-950">{t.name}</p>
                {t.role && <p class="mt-1 text-xs font-bold uppercase tracking-[0.12em] text-dark-900/42">{t.role}</p>}
              </figcaption>
            </figure>
          ))}
        </div>

        <div class="mt-9">
          <a href="/referenzen" class="inline-flex items-center gap-2 border-b-2 border-brand-400 pb-1 text-sm font-extrabold uppercase tracking-[0.14em] text-dark-950 hover:text-brand-600">
            Alle Bewertungen ansehen
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </div>
      </div>
    </section>
  )}

  <!-- FAQ -->
  {enableFaq && (
    <section class="bg-white py-16 sm:py-20 lg:py-24">
      <div class="container-narrow">
        <div class="mb-10">
          <p class="mb-3 text-[0.72rem] font-extrabold uppercase tracking-[0.22em] text-accent-600">Häufig gestellte Fragen</p>
          <h2 class="font-heading text-5xl font-extrabold leading-none text-dark-950 sm:text-6xl">Kurz geklärt.</h2>
          <p class="mt-4 max-w-2xl text-base font-medium leading-relaxed text-dark-900/64">
            Hier finden Sie Antworten auf die wichtigsten Fragen.
          </p>
        </div>

        <div class="border-y border-dark-900/18">
          {faqs.map((item, i) => (
            <details class="group border-b border-dark-900/18 last:border-b-0" id={`faq-${i}`}>
              <summary class="flex cursor-pointer items-center justify-between gap-6 py-6 text-left font-extrabold text-dark-950 list-none [&::-webkit-details-marker]:hidden">
                <span>{item.question}</span>
                <span class="flex h-8 w-8 shrink-0 items-center justify-center bg-brand-400 text-dark-950 transition-transform duration-300 group-open:rotate-45">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="square"><path d="M12 5v14M5 12h14"/></svg>
                </span>
              </summary>
              <div class="pb-6 pr-12 text-dark-900/66 leading-relaxed">
                <p>{item.answer}</p>
              </div>
            </details>
          ))}
        </div>
      </div>
    </section>
  )}

  <Footer slot="footer" />
  <ConsentBanner slot="consent" />
</BaseLayout>
