---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ConsentBanner from '../components/ConsentBanner.astro';
import Hero from '../components/ui/Hero.astro';
import Card from '../components/ui/Card.astro';
import SectionHeading from '../components/ui/SectionHeading.astro';
import Testimonial from '../components/ui/Testimonial.astro';
import FaqAccordion from '../components/ui/FaqAccordion.astro';
import CtaBanner from '../components/ui/CtaBanner.astro';
import PlaceholderImage from '../components/ui/PlaceholderImage.astro';

import allTestimonials from '../data/testimonials.json';
import faqs from '../data/faqs.json';
import services from '../data/services.json';
import processSteps from '../data/process-steps.json';
import stats from '../data/stats.json';

const enableStats = import.meta.env.PUBLIC_ENABLE_STATS === 'true';
const enableLeistungen = import.meta.env.PUBLIC_ENABLE_LEISTUNGEN === 'true';
const enableReferenzen = import.meta.env.PUBLIC_ENABLE_REFERENZEN === 'true';
const enableFaq = import.meta.env.PUBLIC_ENABLE_FAQ === 'true';

const testimonials = allTestimonials.slice(0, 3);
---

<BaseLayout
  title="Energierichter – Unabhängige Energieberatung | Strom & Gas"
  description="Ihr unabhängiger Energierichter: Wir finden den besten Strom- und Gastarif für Privat- und Geschäftskunden. Kostenlos, transparent, unverbindlich."
>
  <Header slot="header" />

  <!-- Hero -->
  <Hero
    badge="Unabhängig · Transparent · Kostenlos"
    title="Energiekosten <span class='text-brand-400'>intelligent</span> senken"
    subtitle="Wir vergleichen über 100 Anbieter und finden den optimalen Strom- & Gastarif für Sie – kostenlos und unverbindlich."
    ctaText="Kostenlos anfragen"
    ctaHref="/anfrage"
    secondaryCtaText="Termin vereinbaren"
    secondaryCtaHref="/termin"
  >
    <PlaceholderImage slot="hero-image" text="Freundliches Beratungsgespräch am Schreibtisch" aspectRatio="aspect-[4/3]" />
  </Hero>

  <!-- Trust Badges -->
  {enableStats && (
    <section class="py-10 bg-gray-50 border-y border-gray-100">
      <div class="container-wide">
        <div class="flex flex-wrap items-center justify-center gap-8 sm:gap-12 text-gray-400">
          {stats.trustBadges.map((badge, i) => (
            <div class="flex items-center gap-2 text-sm">
              {i < 3 ? (
                <svg class="w-5 h-5 text-brand-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  {i === 0 && <path d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>}
                  {i === 1 && <path d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/>}
                  {i === 2 && <path d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>}
                </svg>
              ) : (
                <svg class="w-5 h-5 text-accent-500" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
              )}
              <span class="font-medium text-gray-600">{badge.label}</span>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}


  <!-- Services -->
  {enableLeistungen && (
    <section class="section-padding">
      <div class="container-wide">
        <SectionHeading
          title="Unsere Leistungen"
          subtitle="Von der Tarifanalyse bis zum reibungslosen Wechsel – wir begleiten Sie durch den gesamten Prozess."
        />
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {services.highlight.map((s) => (
            <Card title={s.title} icon={s.icon}>
              {s.description}
            </Card>
          ))}
        </div>
        <div class="text-center mt-10">
          <a href="/leistungen" class="inline-flex items-center gap-2 text-brand-600 font-semibold hover:text-brand-500 transition-colors">
            Alle Leistungen ansehen
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </div>
      </div>
    </section>
  )}


  <!-- Why Energierichter — Alternating Split Section -->
  <section class="section-padding">
    <div class="container-wide">
      <SectionHeading
        title="Warum Energierichter?"
        subtitle="Persönlich, unabhängig und immer auf Ihrer Seite."
      />

      <!-- Row 1: Text left, Image right -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center mb-20">
        <div>
          <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-brand-50 text-brand-600 text-xs font-semibold mb-4">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
            100% unabhängig
          </div>
          <h3 class="text-2xl sm:text-3xl font-heading font-bold text-dark-900 mb-4">Kein Anbieter, sondern <span class="text-brand-600">Ihr Berater</span></h3>
          <p class="text-gray-600 leading-relaxed mb-6">Anders als Vergleichsportale sind wir nicht an bestimmte Energieversorger gebunden. Wir beraten Sie persönlich, analysieren Ihren individuellen Verbrauch und finden den Tarif, der wirklich zu Ihnen passt.</p>
          <ul class="space-y-3">
            <li class="flex items-center gap-3 text-sm text-gray-700">
              <div class="w-6 h-6 rounded-full bg-brand-100 flex items-center justify-center shrink-0"><svg class="w-3.5 h-3.5 text-brand-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path d="M5 13l4 4L19 7"/></svg></div>
              Über 100 Anbieter im Vergleich
            </li>
            <li class="flex items-center gap-3 text-sm text-gray-700">
              <div class="w-6 h-6 rounded-full bg-brand-100 flex items-center justify-center shrink-0"><svg class="w-3.5 h-3.5 text-brand-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path d="M5 13l4 4L19 7"/></svg></div>
              Zugang zu Sonderkonditionen
            </li>
            <li class="flex items-center gap-3 text-sm text-gray-700">
              <div class="w-6 h-6 rounded-full bg-brand-100 flex items-center justify-center shrink-0"><svg class="w-3.5 h-3.5 text-brand-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path d="M5 13l4 4L19 7"/></svg></div>
              Persönlicher Ansprechpartner
            </li>
          </ul>
        </div>
        <div class="relative">
          <div class="absolute -inset-4 bg-gradient-to-br from-brand-100/40 to-transparent rounded-3xl blur-xl"></div>
          <PlaceholderImage text="Berater zeigt Tarifvergleich auf Laptop-Bildschirm" aspectRatio="aspect-[4/3]" class="relative shadow-xl" />
        </div>
      </div>

      <!-- Row 2: Image left, Text right (reversed) -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        <div class="relative order-2 lg:order-1">
          <div class="absolute -inset-4 bg-gradient-to-bl from-accent-100/40 to-transparent rounded-3xl blur-xl"></div>
          <PlaceholderImage text="Zufriedene Familie in hellem Wohnzimmer" aspectRatio="aspect-[4/3]" class="relative shadow-xl" />
        </div>
        <div class="order-1 lg:order-2">
          <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-accent-50 text-accent-700 text-xs font-semibold mb-4">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            Echte Ersparnis
          </div>
          <h3 class="text-2xl sm:text-3xl font-heading font-bold text-dark-900 mb-4">Weniger zahlen, <span class="text-accent-600">mehr genießen</span></h3>
          <p class="text-gray-600 leading-relaxed mb-6">Unsere Kunden sparen im Durchschnitt 420 € pro Jahr – ohne Kompromisse bei der Versorgungssicherheit. Und das Beste: Unser Service ist für Sie komplett kostenlos.</p>
          <div class="grid grid-cols-2 gap-4">
            <div class="bg-white rounded-xl border border-gray-100 p-4 text-center shadow-sm">
              <div class="text-2xl font-heading font-bold text-brand-600">420 €</div>
              <div class="text-xs text-gray-500 mt-1">Ø Ersparnis/Jahr</div>
            </div>
            <div class="bg-white rounded-xl border border-gray-100 p-4 text-center shadow-sm">
              <div class="text-2xl font-heading font-bold text-brand-600">100%</div>
              <div class="text-xs text-gray-500 mt-1">Kostenlos für Sie</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section class="section-padding bg-gray-50">
    <div class="container-wide">
      <SectionHeading
        title="So einfach geht's"
        subtitle="In nur 3 Schritten zu Ihrem optimalen Energietarif"
      />
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-12 items-center">
        <!-- Steps -->
        <div class="lg:col-span-3 grid grid-cols-1 md:grid-cols-3 gap-8">
          {processSteps.homepage.map((item) => (
            <div class="relative text-center p-6">
              <div class="text-6xl font-heading font-extrabold text-brand-100 mb-4">{item.step}</div>
              <h3 class="text-xl font-heading font-bold text-dark-900 mb-2">{item.title}</h3>
              <p class="text-gray-600">{item.description}</p>
            </div>
          ))}
        </div>
        <!-- Companion image -->
        <div class="lg:col-span-2 hidden lg:block">
          <PlaceholderImage text="Person prüft Energierechnung mit Smartphone" aspectRatio="aspect-[3/4]" class="shadow-lg" />
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Banner -->
  <CtaBanner text="Bereit für niedrigere Energiekosten?" ctaText="Jetzt kostenlos anfragen" ctaHref="/anfrage" />

  <!-- Testimonials -->
  {enableReferenzen && (
    <section class="section-padding">
      <div class="container-wide">
        <SectionHeading
          title="Das sagen unsere Kunden"
          subtitle="Überzeugen Sie sich von den Erfahrungen anderer Kunden."
        />
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {testimonials.map((t) => (
            <Testimonial {...t} />
          ))}
        </div>
        <div class="text-center mt-10">
          <a href="/referenzen" class="inline-flex items-center gap-2 text-brand-600 font-semibold hover:text-brand-500 transition-colors">
            Alle Bewertungen ansehen
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </div>
      </div>
    </section>
  )}


  <!-- FAQ -->
  {enableFaq && (
    <section class="section-padding bg-gray-50">
      <div class="container-narrow">
        <SectionHeading
          title="Häufig gestellte Fragen"
          subtitle="Hier finden Sie Antworten auf die wichtigsten Fragen."
        />
        <FaqAccordion items={faqs} />
      </div>
    </section>
  )}


  <Footer slot="footer" />
  <ConsentBanner slot="consent" />
</BaseLayout>
