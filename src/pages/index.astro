---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ConsentBanner from '../components/ConsentBanner.astro';

import HomeHero from '../components/sections/HomeHero.astro';
import StatsRow from '../components/sections/StatsRow.astro';
import PositioningBridge from '../components/sections/PositioningBridge.astro';
import EditorialGridSection from '../components/sections/EditorialGridSection.astro';
import ProcessTimelineSection from '../components/sections/ProcessTimelineSection.astro';
import WhyEnergierichter from '../components/sections/WhyEnergierichter.astro';
import TestimonialsSection from '../components/sections/TestimonialsSection.astro';
import FaqSection from '../components/sections/FaqSection.astro';
import StromGasCompare from '../components/sections/StromGasCompare.astro';
import CtaBanner from '../components/ui/CtaBanner.astro';

import faqs from '../data/faqs.json';
import services from '../data/services.json';
import processSteps from '../data/process-steps.json';
import stats from '../data/stats.json';

const disableStats = import.meta.env.PUBLIC_DISABLE_STATS === 'true';
const disableLeistungen = import.meta.env.PUBLIC_DISABLE_LEISTUNGEN === 'true';
const disableReferenzen = import.meta.env.PUBLIC_DISABLE_REFERENZEN === 'true';
const disableFaq = import.meta.env.PUBLIC_DISABLE_FAQ === 'true';
---

<BaseLayout
  title="Energierichter – Unabhängige Energieberatung | Strom & Gas"
  description="Ihr Unabhängiger Energiemakler: Wir prüfen Ihre Strom- und Gastarife persönlich, vergleichen passende Anbieter und begleiten den Wechsel – kostenlos, transparent, unverbindlich."
>
  <Header slot="header" />

  <HomeHero />

  {!disableStats && (
    <StatsRow items={stats.trustBadges} />
  )}

  <PositioningBridge />

  <StromGasCompare />

  {!disableLeistungen && (
    <EditorialGridSection
      theme="light"
      label="Unsere Leistungen"
      title="Tarifanalyse mit ruhiger Hand."
      subtitle="Von der persönlichen Tarifanalyse bis zum reibungslosen Wechsel – wir begleiten Sie durch den gesamten Prozess, ohne Aufwand für Sie."
      items={services.highlight.map((s, i) => ({ number: `0${i + 1}`, title: s.title, description: s.description }))}
      ctaLink={{ href: '/leistungen', text: 'Alle Leistungen ansehen' }}
      titleSize="3xl"
    />
  )}

  <WhyEnergierichter />

  <ProcessTimelineSection
    label="So einfach geht's"
    title="In drei Schritten zum besseren Tarif."
    subtitle="Vom ersten Kontakt bis zur Bestätigung des neuen Anbieters — wir begleiten Sie durch jeden Schritt."
    items={processSteps.homepage.map(item => ({ number: item.step, title: item.title, description: item.description }))}
    sectionClass="py-20 sm:py-24 lg:py-32"
  />

  <CtaBanner
    label="Nächster Schritt"
    text="Bereit, Ihre Energiekosten prüfen zu lassen?"
    description="Starten Sie mit einer unverbindlichen Tarifprüfung und erfahren Sie, ob sich ein Wechsel für Sie lohnt."
    ctaText="Kostenlose Tarifprüfung starten"
    ctaHref="/anfrage"
    secondaryCtaText="Ablauf ansehen →"
    secondaryCtaHref="/leistungen"
  />

  {!disableReferenzen && (
    <TestimonialsSection
      limit={3}
      showMoreLink={true}
    />
  )}

  {!disableFaq && (
    <FaqSection items={faqs} />
  )}

  <Footer slot="footer" />
  <ConsentBanner slot="consent" />
</BaseLayout>

