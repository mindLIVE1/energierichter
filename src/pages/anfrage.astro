---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ConsentBanner from '../components/ConsentBanner.astro';
import Hero from '../components/ui/Hero.astro';
import AnfrageSection from '../components/sections/AnfrageSection.astro';
---

<BaseLayout
  title="Kostenlos anfragen – Energieberatung | Energierichter"
  description="Senden Sie uns Ihre Anfrage mit Verbrauchsdaten und Dokumenten. Wir finden den besten Energietarif für Sie – kostenlos und unverbindlich."
>
  <Header slot="header" />

  <Hero
    badge="Unverbindliche Anfrage"
    title="Kostenlos anfragen."
    subtitle="Füllen Sie das Formular aus und laden Sie optional Ihre letzte Energierechnung hoch. Wir melden uns innerhalb von 24 Stunden."
  />

  <AnfrageSection />

  <Footer slot="footer" />
  <ConsentBanner slot="consent" />
</BaseLayout>

