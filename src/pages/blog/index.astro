---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ConsentBanner from '../../components/ConsentBanner.astro';
import { getCollection } from 'astro:content';

if (import.meta.env.PUBLIC_ENABLE_BLOG !== 'true') return Astro.redirect('/');


const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<BaseLayout
  title="Blog – Energiemarkt News & Tipps | Energierichter"
  description="Aktuelle Artikel zu Energiemarkt, Spartipps und Branchennews. Bleiben Sie informiert mit dem Energierichter Blog."
>
  <Header slot="header" />

  <!-- Hero -->
  <section class="relative overflow-hidden bg-dark-900 text-white">
    <div class="absolute inset-0 opacity-[0.055] pointer-events-none" style="background-image: linear-gradient(90deg, #ffffff 1px, transparent 1px), linear-gradient(#ffffff 1px, transparent 1px); background-size: 96px 96px;"></div>
    <div class="absolute inset-x-0 bottom-0 h-px bg-brand-400/30"></div>

    <div class="relative container-wide py-20 sm:py-24 lg:py-28 max-w-3xl">
      <p class="mb-5 label-editorial text-brand-300/90">Wissen & Einblicke</p>
      <h1 class="max-w-4xl font-heading text-4xl font-semibold leading-[1.05] text-white sm:text-5xl lg:text-6xl xl:text-7xl">
        Blog
      </h1>
      <p class="mt-7 max-w-2xl text-base sm:text-lg leading-8 text-white/66">
        Aktuelle Tipps, News und Expertenwissen rund um Energie.
      </p>
    </div>
  </section>

  <section class="bg-[#f7f3ea] py-20 sm:py-24 lg:py-32">
    <div class="container-wide">
      {posts.length === 0 ? (
        <p class="text-center text-dark-700/60">Noch keine Artikel vorhanden.</p>
      ) : (
        <div class="grid gap-px bg-dark-900/12 border border-dark-900/12 md:grid-cols-2 lg:grid-cols-3">
          {posts.map((post) => (
            <a href={`/blog/${post.slug}`} class="group bg-[#f7f3ea] hover:bg-[#f0ece3] transition-colors duration-200 block">
              <div class="h-48 bg-[#eae5d9] flex items-center justify-center border-b border-dark-900/12">
                <svg class="w-10 h-10 text-dark-700/20 group-hover:text-brand-500 transition-colors duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg>
              </div>
              <div class="p-7">
                <div class="flex items-center gap-2 text-xs text-dark-700/50 mb-3">
                  <time datetime={post.data.pubDate.toISOString()}>
                    {post.data.pubDate.toLocaleDateString('de-DE', { day: 'numeric', month: 'long', year: 'numeric' })}
                  </time>
                  {post.data.author && <span>· {post.data.author}</span>}
                </div>
                <h2 class="text-lg font-heading font-semibold text-dark-900 mb-2 group-hover:text-brand-700 transition-colors">
                  {post.data.title}
                </h2>
                <p class="text-sm text-dark-700 line-clamp-2">{post.data.description}</p>
                {post.data.tags.length > 0 && (
                  <div class="flex flex-wrap gap-2 mt-4">
                    {post.data.tags.slice(0, 3).map((tag) => (
                      <span class="px-2 py-0.5 text-[0.64rem] font-semibold uppercase tracking-[0.14em] text-brand-700 border border-brand-500/30">{tag}</span>
                    ))}
                  </div>
                )}
              </div>
            </a>
          ))}
        </div>
      )}
    </div>
  </section>

  <Footer slot="footer" />
  <ConsentBanner slot="consent" />
</BaseLayout>
