---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ConsentBanner from '../../components/ConsentBanner.astro';
import Hero from '../../components/ui/Hero.astro';
import BlogGridSection from '../../components/sections/BlogGridSection.astro';

if (import.meta.env.PUBLIC_DISABLE_BLOG === 'true') return Astro.redirect('/');
---

<BaseLayout
  title="Blog – Energiemarkt News & Tipps | Energierichter"
  description="Aktuelle Artikel zu Energiemarkt, Spartipps und Branchennews. Bleiben Sie informiert mit dem Energierichter Blog."
>
  <Header slot="header" />

  <Hero
    badge="Wissen & Einblicke"
    title="Blog"
    subtitle="Aktuelle Tipps, News und Expertenwissen rund um Energie."
  />

  <BlogGridSection />

  <Footer slot="footer" />
  <ConsentBanner slot="consent" />
</BaseLayout>

