---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ConsentBanner from '../components/ConsentBanner.astro';
import SectionHeading from '../components/ui/SectionHeading.astro';
import Testimonial from '../components/ui/Testimonial.astro';
import CtaBanner from '../components/ui/CtaBanner.astro';

import testimonials from '../data/testimonials.json';
import stats from '../data/stats.json';

if (import.meta.env.PUBLIC_ENABLE_REFERENZEN !== 'true') return Astro.redirect('/');
---

<BaseLayout
  title="Referenzen & Bewertungen | Energierichter"
  description="Lesen Sie, was unsere Kunden über uns sagen. Über 5.000 zufriedene Kunden vertrauen Energierichter."
>
  <Header slot="header" />

  <section class="section-padding">
    <div class="container-wide">
      <SectionHeading
        title="Referenzen & Bewertungen"
        subtitle="Über 5.000 zufriedene Kunden vertrauen uns. Lesen Sie ihre Erfahrungen."
      />

      <!-- Stats -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 mb-16">
        {stats.referenzenStats.map((stat) => (
          <div class="bg-white rounded-2xl border border-gray-100 shadow-md p-6 text-center">
            <div class="text-3xl font-heading font-bold text-brand-600 mb-1">{stat.value}</div>
            <div class="text-sm text-gray-500">{stat.label}</div>
          </div>
        ))}
      </div>

      <!-- Testimonials Grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {testimonials.map((t) => (
          <Testimonial {...t} />
        ))}
      </div>
    </div>
  </section>

  <CtaBanner text="Überzeugt? Starten Sie jetzt." ctaText="Kostenlos anfragen" ctaHref="/anfrage" />

  <Footer slot="footer" />
  <ConsentBanner slot="consent" />
</BaseLayout>
