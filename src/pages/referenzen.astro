---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ConsentBanner from '../components/ConsentBanner.astro';
import Hero from '../components/ui/Hero.astro';
import StatsRow from '../components/sections/StatsRow.astro';
import TestimonialsSection from '../components/sections/TestimonialsSection.astro';
import CtaBanner from '../components/ui/CtaBanner.astro';

import stats from '../data/stats.json';

if (import.meta.env.PUBLIC_DISABLE_REFERENZEN === 'true') return Astro.redirect('/');
---

<BaseLayout
  title="Referenzen & Bewertungen | Energierichter"
  description="Lesen Sie, was unsere Kunden über uns sagen. Über 5.000 zufriedene Kunden vertrauen Energierichter."
>
  <Header slot="header" />

  <Hero
    badge="Kundenstimmen"
    title="Geprüft in der Praxis."
    subtitle="Über 5.000 zufriedene Kunden vertrauen uns. Lesen Sie ihre Erfahrungen."
  />

  <StatsRow
    items={stats.referenzenStats}
    bgColor="bg-[#111820] border-b border-white/10"
  />

  <TestimonialsSection
    showAll={true}
    label="Das sagen unsere Kunden"
    title="Echte Erfahrungen."
    subtitle="Überzeugen Sie sich von den Ergebnissen unserer Beratung."
  />

  <CtaBanner text="Überzeugt? Starten Sie jetzt." ctaText="Kostenlos anfragen" ctaHref="/anfrage" />

  <Footer slot="footer" />
  <ConsentBanner slot="consent" />
</BaseLayout>

