---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ConsentBanner from '../components/ConsentBanner.astro';
import Hero from '../components/ui/Hero.astro';
import TransparenzCoreSection from '../components/sections/TransparenzCoreSection.astro';
import EditorialGridSection from '../components/sections/EditorialGridSection.astro';
import TrustQnaSection from '../components/sections/TrustQnaSection.astro';
import CtaBanner from '../components/ui/CtaBanner.astro';

import transparenzData from '../data/transparenz.json';

if (import.meta.env.PUBLIC_DISABLE_TRANSPARENZ === 'true') return Astro.redirect('/');
---

<BaseLayout
  title="Transparenz & Vergütung – So verdienen wir | Energierichter"
  description="Erfahren Sie, wie unser Geschäftsmodell funktioniert: kostenlos für Sie, vergütet durch die Energieversorger. Volle Transparenz ohne versteckte Kosten."
>
  <Header slot="header" />

  <Hero
    badge="Offenheit & Vertrauen"
    title="Transparenz & Vergütung"
    subtitle="Wir glauben an Offenheit. Hier erklären wir, wie unser Geschäftsmodell funktioniert."
  />

  <TransparenzCoreSection />

  <EditorialGridSection
    theme="light"
    container="narrow"
    items={transparenzData.cards.map((card, i) => ({ number: String(i + 1).padStart(2, '0'), title: card.title, description: card.description }))}
    sectionClass="py-8 bg-[#f7f3ea]"
  />

  <TrustQnaSection />

  <CtaBanner text="Transparente Beratung, echte Ersparnis." ctaText="Jetzt kostenlos anfragen" ctaHref="/anfrage" label="Überzeugt?" />

  <Footer slot="footer" />
  <ConsentBanner slot="consent" />
</BaseLayout>

